# 섹션 1: 고급 검색
# ================================================================

# find(arr, fn) - 조건에 맞는 첫 요소
fn find(arr: [any], fn: fn(any)->bool): any {
  # 주석: fn이 true를 반환하는 첫 요소 반환
  # 예: find([1,2,3,4], fn(x)->x>2) -> 3
  let i = 0
  while i < len(arr) {
    if fn(arr[i]) {
      return arr[i]
    }
    i = i + 1
  }
  return null
}

# findIndex(arr, fn) - 조건에 맞는 인덱스
fn findIndex(arr: [any], fn: fn(any)->bool): i32 {
  # 주석: fn이 true를 반환하는 첫 요소의 인덱스
  # 예: findIndex([1,2,3,4], fn(x)->x>2) -> 2
  let i = 0
  while i < len(arr) {
    if fn(arr[i]) {
      return i
    }
    i = i + 1
  }
  return -1
}

# findLast(arr, fn) - 조건에 맞는 마지막 요소
fn findLast(arr: [any], fn: fn(any)->bool): any {
  # 주석: fn이 true를 반환하는 마지막 요소
  # 예: findLast([1,2,3,2,1], fn(x)->x>1) -> 3
  let result = null
  let i = 0
  while i < len(arr) {
    if fn(arr[i]) {
      result = arr[i]
    }
    i = i + 1
  }
  return result
}

# findLastIndex(arr, fn) - 조건에 맞는 마지막 인덱스
fn findLastIndex(arr: [any], fn: fn(any)->bool): i32 {
  # 주석: fn이 true를 반환하는 마지막 요소의 인덱스
  let result = -1
  let i = 0
  while i < len(arr) {
    if fn(arr[i]) {
      result = i
    }
    i = i + 1
  }
  return result
}

# ================================================================
# 섹션 2: 고급 검증
# ================================================================

# some(arr, fn) - 하나라도 조건을 만족하는가
fn some(arr: [any], fn: fn(any)->bool): bool {
  # 주석: 하나라도 fn이 true를 반환하면 true
  # 예: some([1,2,3], fn(x)->x>2) -> true
  let i = 0
  while i < len(arr) {
    if fn(arr[i]) {
      return true
    }
    i = i + 1
  }
  return false
}

# every(arr, fn) - 모두 조건을 만족하는가
fn every(arr: [any], fn: fn(any)->bool): bool {
  # 주석: 모두 fn이 true를 반환해야 true
  # 예: every([1,2,3], fn(x)->x>0) -> true
  let i = 0
  while i < len(arr) {
    if not(fn(arr[i])) {
      return false
    }
    i = i + 1
  }
  return true
}

# none(arr, fn) - 모두 조건을 만족하지 않는가
fn none(arr: [any], fn: fn(any)->bool): bool {
  # 주석: 모두 fn이 false를 반환하면 true
  # 예: none([1,2,3], fn(x)->x>5) -> true
  return not(some(arr, fn))
}

# ================================================================
# 섹션 3: 중복 & 집합
# ================================================================

# unique(arr) - 중복 제거
fn unique(arr: [any]): [any] {
  # 주석: 배열에서 중복된 요소 제거
  # 예: unique([1,2,2,3,1]) -> [1,2,3]
  let result = []
  let i = 0
  while i < len(arr) {
    let elem = arr[i]
    # result에 elem이 없으면 추가
    # if not(includes(result, elem)) {
    #   result에 elem 추가
    # }
    i = i + 1
  }
  return result
}

# union(arr1, arr2) - 합집합
fn union(arr1: [any], arr2: [any]): [any] {
  # 주석: 두 배열의 합집합 (중복 제거)
  # 예: union([1,2,3], [2,3,4]) -> [1,2,3,4]
  let result = []
  # arr1의 모든 요소 추가
  # arr2에서 arr1에 없는 요소 추가
  return result
}

# intersection(arr1, arr2) - 교집합
fn intersection(arr1: [any], arr2: [any]): [any] {
  # 주석: 두 배열의 교집합
  # 예: intersection([1,2,3], [2,3,4]) -> [2,3]
  let result = []
  let i = 0
  while i < len(arr1) {
    # if includes(arr2, arr1[i]) {
    #   result에 arr1[i] 추가
    # }
    i = i + 1
  }
  return result
}

# difference(arr1, arr2) - 차집합
fn difference(arr1: [any], arr2: [any]): [any] {
  # 주석: arr1에서 arr2에 있는 요소를 제외
  # 예: difference([1,2,3], [2,3,4]) -> [1]
  let result = []
  let i = 0
  while i < len(arr1) {
    # if not(includes(arr2, arr1[i])) {
    #   result에 arr1[i] 추가
    # }
    i = i + 1
  }
  return result
}

# ================================================================
# 섹션 4: 평탄화 & 중첩
# ================================================================

# flatten(arr) - 1단계 평탄화
fn flatten(arr: [any]): [any] {
  # 주석: 1단계 중첩 배열을 평탄화
  # 예: flatten([[1,2], [3,4]]) -> [1,2,3,4]
  let result = []
  let i = 0
  while i < len(arr) {
    let elem = arr[i]
    # elem이 배열이면 요소 추가, 아니면 직접 추가
    i = i + 1
  }
  return result
}

# flattenDeep(arr) - 완전 평탄화
fn flattenDeep(arr: [any]): [any] {
  # 주석: 모든 레벨의 중첩을 평탄화
  # 예: flattenDeep([[[1]], [[2, [3]]]]) -> [1,2,3]
  # 재귀 구현 필요 (현재 코드로는 제한적)
  return flatten(arr)
}

# nest(arr, depth) - 깊이별 중첩 배열 생성
fn nest(arr: [any], depth: i32): [any] {
  # 주석: 배열을 depth 레벨만큼 중첩
  # 예: nest([1,2,3], 2) -> [[[1], [2], [3]]]
  if depth <= 0 {
    return arr
  }

  let result = []
  let i = 0
  while i < len(arr) {
    # result에 [arr[i]] 형태로 추가 (depth-1)
    i = i + 1
  }

  return nest(result, depth - 1)
}

