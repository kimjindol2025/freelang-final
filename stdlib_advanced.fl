# groupBy(arr, keyFn) - 키별 그룹화 (간단한 버전)
fn groupBy(arr: [any], keyFn: fn(any)->string): any {
  # 주석: keyFn의 반환값을 기준으로 그룹화
  # 예: groupBy([{g:1,v:5}, {g:1,v:6}, {g:2,v:7}],
  #            fn(x)->x.g)
  # 반환: {1: [...], 2: [...]}
  # TODO: Object 생성 로직 복잡 - 스킵
  return null
}

# keyBy(arr, keyFn) - 키별 객체 생성
fn keyBy(arr: [any], keyFn: fn(any)->string): any {
  # 주석: 배열을 객체로 변환 (key:value 쌍)
  # 예: keyBy([{id:1,name:"a"}, {id:2,name:"b"}],
  #         fn(x)->x.id)
  # 반환: {1: {id:1,name:"a"}, 2: {id:2,name:"b"}}
  return null
}

# indexBy(arr, keyFn) - keyBy의 별칭
fn indexBy(arr: [any], keyFn: fn(any)->string): any {
  return keyBy(arr, keyFn)
}

