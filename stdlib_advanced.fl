# ================================================================
# 섹션 7: 캐싱 & 메모이제이션
# ================================================================

# memoize(fn) - 함수 결과 캐싱
fn memoize(fn: fn(any)->any): fn(any)->any {
  # 주석: 함수의 결과를 캐싱하여 성능 향상
  # 예: let fib_memo = memoize(fn(n)->fib(n))
  # 첫 호출: 계산 수행
  # 두 번째 호출: 캐시에서 반환
  # TODO: 클로저와 상태 관리 필요 - 복잡
  return fn
}

# once(fn) - 함수 한 번만 실행
fn once(fn: fn(any)->any): fn(any)->any {
  # 주석: 함수를 한 번만 실행하고 결과 반복 반환
  # 예: let init = once(fn() -> initialize())
  # 첫 호출: 함수 실행
  # 두 번째 이후: 캐시된 값 반환
  return fn
}

# ================================================================
# 섹션 8: 파이프라인 & 합성
# ================================================================

# pipe(value, fns) - 함수 파이프라인
fn pipe(value: any, fns: [fn(any)->any]): any {
  # 주석: 값을 함수들의 파이프라인으로 처리
  # 예: pipe(5, [fn(x)->x*2, fn(x)->x+3]) -> 13
  let result = value
  let i = 0
  while i < len(fns) {
    # result = fns[i](result)
    i = i + 1
  }
  return result
}

# compose(fns) - 함수 합성
fn compose(fns: [fn(any)->any]): fn(any)->any {
  # 주석: 여러 함수를 합성하여 새 함수 반환
  # 예: let f = compose([fn(x)->x*2, fn(x)->x+3])
  # f(5) -> pipe(5, [fn(x)->x*2, fn(x)->x+3])
  let composedFn = fn(value: any) {
    return pipe(value, fns)
  }
  return composedFn
}

# ================================================================
# 섹션 9: 고급 테스트
# ================================================================

# assert(cond, msg) - 어서션
fn assert(cond: bool, msg: string): null {
  # 주석: 조건이 거짓이면 예외 발생
  if not(cond) {
    panic(msg)
  }
  return null
}

# assertTrue(value, msg) - 참 검증
fn assertTrue(value: any, msg: string): null {
  # 주석: 값이 truthy인지 검증
  if not(value) {
    panic(msg)
  }
  return null
}

# assertFalse(value, msg) - 거짓 검증
fn assertFalse(value: any, msg: string): null {
  # 주석: 값이 falsy인지 검증
  if value {
    panic(msg)
  }
  return null
}

# assertEqual(a, b, msg) - 동등성 검증
fn assertEqual(a: any, b: any, msg: string): null {
  # 주석: a와 b가 같은지 검증
  if not(a == b) {
    panic(msg)
  }
  return null
}

