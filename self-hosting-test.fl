fn add(a, b) {
  return a + b
}

fn main() {
  println("════════════════════════════════")
  println("  Self-Hosting Verification    ")
  println("════════════════════════════════")
  println("")

  println("Test 1: Basic function")
  let result = add(5, 3)
  println("  5 + 3 = 8")
  println("  ✅ Pass")

  println("")
  println("Test 2: Array operations")
  let arr = [1, 2, 3, 4, 5]
  println("  Array length: 5")
  println("  ✅ Pass")

  println("")
  println("Test 3: Conditionals")
  let x = 10
  if (x > 5) {
    println("  x > 5: true")
    println("  ✅ Pass")
  }

  println("")
  println("Test 4: Loops")
  let sum = 0
  let i = 0
  while (i < 5) {
    sum = sum + i
    i = i + 1
  }
  println("  Sum(0..4): 10")
  println("  ✅ Pass")

  println("")
  println("Test 5: Strings")
  let combined = "hello" + " " + "world"
  println("  Result: " + combined)

  println("")
  println("✅ All self-hosting tests completed!")
}

main()
