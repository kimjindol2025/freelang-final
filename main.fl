# ================================================================
# Part 5: 메인 진입점
# ================================================================

fn main(args: [string]): i32 {
  let env = createEnv()
  
  let config = parseArgs(args)
  let mode = config["mode"]
  
  if mode == "repl" {
    runRepl(env)
    return 0
  } else if mode == "eval" {
    let code = config["code"]
    let result = execute(code, env)
    return 0
  } else if mode == "file" {
    let filename = config["filename"]
    let result = runFile(filename, env)
    return 0
  } else {
    return 1
  }
}

