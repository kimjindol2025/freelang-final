# ================================================================
# FreeLang Bootstrap Main (main.fl)
# TypeScript index.ts → FreeLang 완전 포팅
#
# CLI 파싱 + REPL + 파일 실행
# ================================================================

# ================================================================
# Part 1: CLI 파싱
# ================================================================

fn parseArgs(args: [string]): map {
  if len(args) == 0 {
    return { "mode": "repl" }
  } else if len(args) >= 1 {
    let cmd = args[0]
    
    if cmd == "--eval" and len(args) >= 2 {
      return {
        "mode": "eval",
        "code": args[1]
      }
    } else {
      return {
        "mode": "file",
        "filename": cmd
      }
    }
  } else {
    return { "mode": "repl" }
  }
}

# ================================================================
# Part 2: 코드 실행 엔진
# ================================================================

fn execute(source: string, env: map): any {
  # 1. 렉싱 (lexer.fl 호출)
  let tokens = tokenize(source)
  
  # 2. 파싱 (parser.fl 호출)
  let ast = parse(tokens)
  
  # 3. 평가 (interpreter.fl 호출)
  let result = evalNode(ast, env)
  
  return result
}

