/**
 * ═══════════════════════════════════════════════════════════════════════════
 * FreeLang Complete Self-Hosting Compiler (All Stages Integrated)
 * ═══════════════════════════════════════════════════════════════════════════
 *
 * 통합 컴파일러 (2,687 줄)
 *   Stage 1: Lexer (tokenization)
 *   Stage 2: Parser (AST generation)  
 *   Stage 3: IR Generator (intermediate representation)
 *   Stage 4: x86-64 Encoder (machine code)
 *   Stage 5: ELF Builder (executable format)
 *
 * 이 파일은 Stage 1-5 모든 구성요소를 포함하여
 * 자기 자신을 컴파일할 수 있는 완전한 프리랭 컴파일러입니다.
 *
 * 사용법:
 *   node full-e2e-compiler.js freelang-compiler-complete.fl
 *   → freelang-compiler-v1 생성
 *
 * ═══════════════════════════════════════════════════════════════════════════
 */

// ════════════════════════════════════════════════════════════════════════════
// STAGE 1: LEXER (Tokenization)
// ════════════════════════════════════════════════════════════════════════════

/**
 * FreeLang Self-Hosting Lexer (Pure v2 Implementation)
 *
 * 자체호스팅 Lexer - FreeLang으로 작성된 토크나이저
 *
 * ⚠️ 제약사항:
 *   - struct 선언 금지 (객체 리터럴만 사용)
 *   - JS 메서드 금지 (.charCodeAt, .charAt, .length 등)
 *   - v2 stdlib 함수만 사용 (charAt, string_length, substr 등)
 *
 * 기능:
 *   - 키워드, 식별자, 숫자, 문자열 인식
 *   - 연산자 및 구두점 토크나이제이션
 *   - 라인/컬럼 위치 추적
 *   - 주석 처리 (라인, 블록)
 *
 * 예시:
 *   let code = "fn add(a, b) { return a + b }"
 *   let tokens = tokenize(code)
 *   // [{kind: "KEYWORD", value: "fn"}, {kind: "IDENT", value: "add"}, ...]
 */

// ============================================
// 1. Token 객체 생성 함수 (struct 대신 사용)
// ============================================

/**
 * Token 객체 생성
 * {kind, value, line, col, length}
 */
fn makeToken(kind, value, line, col, length) {
  return {
    kind: kind,
    value: value,
    line: line,
    col: col,
    length: length
  }
}

// ============================================
// 2. Lexer 상태 객체 생성
// ============================================

/**
 * Lexer 초기화
 * {source, pos, line, col, tokens}
 */
fn createLexer(source) {
  return {
    source: source,
    pos: 0,
    line: 1,
    col: 1,
    tokens: []
  }
}

// ============================================
// 3. 기본 문자 조회 함수
// ============================================

/**
 * 현재 위치의 문자 반환
 * 끝이면 ""
 */
fn current(lexer) {
  let p = lexer.pos
  let s = lexer.source
  let len = string_length(s)

  if (p >= len) {
    return ""
  }
  return charAt(s, p)
}

/**
 * offset만큼 앞의 문자 미리보기
 * 예: peek(lexer, 1) = 다음 문자
 */
fn peek(lexer, offset) {
  let p = lexer.pos + offset
  let s = lexer.source
  let len = string_length(s)

  if (p >= len) {
    return ""
  }
  return charAt(s, p)
}

/**
 * 현재 위치 전진
 * 줄바꿈 시 line++, col 리셋
 */
fn advance(lexer) {
  let ch = current(lexer)

  if (ch == "\n") {
    lexer.line = lexer.line + 1
    lexer.col = 1
  } else {
    lexer.col = lexer.col + 1
  }
  lexer.pos = lexer.pos + 1
}

// ============================================
// 4. 문자 검사 함수들
// ============================================

/**
 * 알파벳 검사 (a-z, A-Z, _)
 * ASCII 코드 비교로 구현
 */
fn isAlpha(ch) {
  if (ch == "") {
    return 0
  }

  // ASCII를 사용하지 않고 문자 직접 비교
  let c0 = charAt("abcdefghijklmnopqrstuvwxyz", 0)
  let c1 = charAt("ABCDEFGHIJKLMNOPQRSTUVWXYZ", 0)
  let c2 = charAt("_", 0)

  // 간단히: 소문자 a-z 포함
  if (ch == "a") { return 1 }
  if (ch == "b") { return 1 }
  if (ch == "c") { return 1 }
  if (ch == "d") { return 1 }
  if (ch == "e") { return 1 }
  if (ch == "f") { return 1 }
  if (ch == "g") { return 1 }
  if (ch == "h") { return 1 }
  if (ch == "i") { return 1 }
  if (ch == "j") { return 1 }
  if (ch == "k") { return 1 }
  if (ch == "l") { return 1 }
  if (ch == "m") { return 1 }
  if (ch == "n") { return 1 }
  if (ch == "o") { return 1 }
  if (ch == "p") { return 1 }
  if (ch == "q") { return 1 }
  if (ch == "r") { return 1 }
  if (ch == "s") { return 1 }
  if (ch == "t") { return 1 }
  if (ch == "u") { return 1 }
  if (ch == "v") { return 1 }
  if (ch == "w") { return 1 }
  if (ch == "x") { return 1 }
  if (ch == "y") { return 1 }
  if (ch == "z") { return 1 }

  // 대문자 A-Z
  if (ch == "A") { return 1 }
  if (ch == "B") { return 1 }
  if (ch == "C") { return 1 }
  if (ch == "D") { return 1 }
  if (ch == "E") { return 1 }
  if (ch == "F") { return 1 }
  if (ch == "G") { return 1 }
  if (ch == "H") { return 1 }
  if (ch == "I") { return 1 }
  if (ch == "J") { return 1 }
  if (ch == "K") { return 1 }
  if (ch == "L") { return 1 }
  if (ch == "M") { return 1 }
  if (ch == "N") { return 1 }
  if (ch == "O") { return 1 }
  if (ch == "P") { return 1 }
  if (ch == "Q") { return 1 }
  if (ch == "R") { return 1 }
  if (ch == "S") { return 1 }
  if (ch == "T") { return 1 }
  if (ch == "U") { return 1 }
  if (ch == "V") { return 1 }
  if (ch == "W") { return 1 }
  if (ch == "X") { return 1 }
  if (ch == "Y") { return 1 }
  if (ch == "Z") { return 1 }

  // 언더스코어
  if (ch == "_") { return 1 }

  return 0
}

/**
 * 숫자 검사 (0-9)
 */
fn isDigit(ch) {
  if (ch == "") {
    return 0
  }

  if (ch == "0") { return 1 }
  if (ch == "1") { return 1 }
  if (ch == "2") { return 1 }
  if (ch == "3") { return 1 }
  if (ch == "4") { return 1 }
  if (ch == "5") { return 1 }
  if (ch == "6") { return 1 }
  if (ch == "7") { return 1 }
  if (ch == "8") { return 1 }
  if (ch == "9") { return 1 }

  return 0
}

/**
 * 알파벳 또는 숫자 검사
 */
fn isAlphaNumeric(ch) {
  let a = isAlpha(ch)
  let d = isDigit(ch)

  if (a == 1) { return 1 }
  if (d == 1) { return 1 }

  return 0
}

/**
 * 공백 문자 검사 (space, tab, newline, carriage return)
 */
fn isWhitespace(ch) {
  if (ch == " ") { return 1 }
  if (ch == "\t") { return 1 }
  if (ch == "\n") { return 1 }
  if (ch == "\r") { return 1 }

  return 0
}

// ============================================
// 5. 주석 스킵 함수
// ============================================

/**
 * 라인 주석 스킵 (// 처리)
 */
fn skipLineComment(lexer) {
  // // 두 글자 건너뛰기
  advance(lexer)
  advance(lexer)

  // 줄 끝까지 읽기
  let ch = current(lexer)
  while (ch != "" && ch != "\n") {
    advance(lexer)
    ch = current(lexer)
  }

  // \n 도달 시 한 번 더 advance (줄 넘기기)
  if (ch == "\n") {
    advance(lexer)
  }
}

/**
 * 블록 주석 스킵 (/* */ 처리)
 */
fn skipBlockComment(lexer) {
  // /* 두 글자 건너뛰기
  advance(lexer)
  advance(lexer)

  // */ 찾을 때까지 읽기
  let ch = current(lexer)
  let next_ch = peek(lexer, 1)

  while (ch != "") {
    if (ch == "*" && next_ch == "/") {
      // */ 도달
      advance(lexer)  // *
      advance(lexer)  // /
      break
    }
    advance(lexer)
    ch = current(lexer)
    next_ch = peek(lexer, 1)
  }
}

/**
 * 공백과 주석 건너뛰기
 */
fn skipWhitespace(lexer) {
  let ch = current(lexer)

  while (ch != "") {
    // 공백 문자
    if (isWhitespace(ch) == 1) {
      advance(lexer)
      ch = current(lexer)
      continue
    }

    // 라인 주석
    if (ch == "/" && peek(lexer, 1) == "/") {
      skipLineComment(lexer)
      ch = current(lexer)
      continue
    }

    // 블록 주석
    if (ch == "/" && peek(lexer, 1) == "*") {
      skipBlockComment(lexer)
      ch = current(lexer)
      continue
    }

    // 공백/주석 아님
    break
  }
}

// ============================================
// 6. 키워드 검사 함수
// ============================================

/**
 * 키워드 검사
 */
fn isKeyword(word) {
  if (word == "fn") { return 1 }
  if (word == "let") { return 1 }
  if (word == "return") { return 1 }
  if (word == "if") { return 1 }
  if (word == "else") { return 1 }
  if (word == "while") { return 1 }
  if (word == "for") { return 1 }
  if (word == "in") { return 1 }
  if (word == "break") { return 1 }
  if (word == "continue") { return 1 }
  if (word == "match") { return 1 }
  if (word == "struct") { return 1 }
  if (word == "enum") { return 1 }
  if (word == "impl") { return 1 }
  if (word == "trait") { return 1 }
  if (word == "type") { return 1 }
  if (word == "as") { return 1 }
  if (word == "pub") { return 1 }
  if (word == "mut") { return 1 }
  if (word == "const") { return 1 }
  if (word == "static") { return 1 }
  if (word == "async") { return 1 }
  if (word == "await") { return 1 }
  if (word == "try") { return 1 }
  if (word == "catch") { return 1 }
  if (word == "throw") { return 1 }
  if (word == "true") { return 1 }
  if (word == "false") { return 1 }
  if (word == "null") { return 1 }
  if (word == "undefined") { return 1 }

  return 0
}

// ============================================
// 7. 식별자/키워드 스캔
// ============================================

/**
 * 식별자 또는 키워드 스캔
 * 문자나 언더스코어로 시작
 * 문자, 숫자, 언더스코어 포함 가능
 */
fn scanIdentifier(lexer) {
  let start_line = lexer.line
  let start_col = lexer.col
  let start_pos = lexer.pos

  // 식별자 문자 읽기
  let word = ""
  let ch = current(lexer)

  while (ch != "" && isAlphaNumeric(ch) == 1) {
    word = word + ch
    advance(lexer)
    ch = current(lexer)
  }

  // 키워드 여부 확인
  let kind = "IDENT"
  if (isKeyword(word) == 1) {
    kind = "KEYWORD"
  }

  let len = string_length(word)
  return makeToken(kind, word, start_line, start_col, len)
}

// ============================================
// 8. 숫자 스캔
// ============================================

/**
 * 숫자 스캔 (정수 및 실수)
 * 예: 123, 123.456, .456
 */
fn scanNumber(lexer) {
  let start_line = lexer.line
  let start_col = lexer.col
  let start_pos = lexer.pos

  let num = ""
  let ch = current(lexer)

  // 정수 부분
  while (ch != "" && isDigit(ch) == 1) {
    num = num + ch
    advance(lexer)
    ch = current(lexer)
  }

  // 소수점 처리
  if (ch == "." && isDigit(peek(lexer, 1)) == 1) {
    num = num + ch
    advance(lexer)
    ch = current(lexer)

    // 소수 부분
    while (ch != "" && isDigit(ch) == 1) {
      num = num + ch
      advance(lexer)
      ch = current(lexer)
    }
  }

  let len = string_length(num)
  return makeToken("NUMBER", num, start_line, start_col, len)
}

// ============================================
// 9. 문자열 스캔
// ============================================

/**
 * 문자열 스캔 ("..." 처리)
 * 이스케이프 시퀀스: \n, \t, \\, \"
 */
fn scanString(lexer) {
  let start_line = lexer.line
  let start_col = lexer.col

  // 시작 따옴표 건너뛰기
  advance(lexer)

  let str = ""
  let ch = current(lexer)

  while (ch != "" && ch != "\"") {
    if (ch == "\\") {
      // 이스케이프 시퀀스
      advance(lexer)
      let next = current(lexer)

      if (next == "n") {
        str = str + "\n"
      } else if (next == "t") {
        str = str + "\t"
      } else if (next == "\\") {
        str = str + "\\"
      } else if (next == "\"") {
        str = str + "\""
      } else {
        // 알 수 없는 이스케이프: 그냥 문자 추가
        str = str + next
      }

      advance(lexer)
      ch = current(lexer)
    } else {
      str = str + ch
      advance(lexer)
      ch = current(lexer)
    }
  }

  // 종료 따옴표 건너뛰기
  if (ch == "\"") {
    advance(lexer)
  }

  let len = string_length(str)
  return makeToken("STRING", str, start_line, start_col, len)
}

// ============================================
// 10. 연산자 및 구두점 스캔
// ============================================

/**
 * 2글자 연산자 검사
 * ==, !=, <=, >=, &&, ||, ++, --, ->, =>
 */
fn checkTwoCharOp(lexer) {
  let ch = current(lexer)
  let next = peek(lexer, 1)

  if (ch == "=" && next == "=") { return "==" }
  if (ch == "!" && next == "=") { return "!=" }
  if (ch == "<" && next == "=") { return "<=" }
  if (ch == ">" && next == "=") { return ">=" }
  if (ch == "&" && next == "&") { return "&&" }
  if (ch == "|" && next == "|") { return "||" }
  if (ch == "+" && next == "+") { return "++" }
  if (ch == "-" && next == "-") { return "--" }
  if (ch == "-" && next == ">") { return "->" }
  if (ch == "=" && next == ">") { return "=>" }

  return ""
}

/**
 * 단일 문자 연산자/구두점
 */
fn isSingleCharOp(ch) {
  if (ch == "+") { return 1 }
  if (ch == "-") { return 1 }
  if (ch == "*") { return 1 }
  if (ch == "/") { return 1 }
  if (ch == "=") { return 1 }
  if (ch == "!") { return 1 }
  if (ch == "<") { return 1 }
  if (ch == ">") { return 1 }
  if (ch == "&") { return 1 }
  if (ch == "|") { return 1 }
  if (ch == "^") { return 1 }
  if (ch == "%") { return 1 }
  if (ch == "~") { return 1 }
  if (ch == ".") { return 1 }
  if (ch == ",") { return 1 }
  if (ch == ";") { return 1 }
  if (ch == ":") { return 1 }
  if (ch == "?") { return 1 }
  if (ch == "@") { return 1 }
  if (ch == "#") { return 1 }

  return 0
}

/**
 * 연산자 또는 구두점 스캔
 */
fn scanOperator(lexer) {
  let start_line = lexer.line
  let start_col = lexer.col

  // 2글자 연산자 먼저 확인
  let op = checkTwoCharOp(lexer)
  if (op != "") {
    advance(lexer)
    advance(lexer)
    return makeToken("OP", op, start_line, start_col, 2)
  }

  // 단일 문자 연산자
  let ch = current(lexer)
  if (isSingleCharOp(ch) == 1) {
    advance(lexer)
    return makeToken("OP", ch, start_line, start_col, 1)
  }

  // 괄호 및 중괄호
  if (ch == "(") {
    advance(lexer)
    return makeToken("LPAREN", "(", start_line, start_col, 1)
  }
  if (ch == ")") {
    advance(lexer)
    return makeToken("RPAREN", ")", start_line, start_col, 1)
  }
  if (ch == "{") {
    advance(lexer)
    return makeToken("LBRACE", "{", start_line, start_col, 1)
  }
  if (ch == "}") {
    advance(lexer)
    return makeToken("RBRACE", "}", start_line, start_col, 1)
  }
  if (ch == "[") {
    advance(lexer)
    return makeToken("LBRACKET", "[", start_line, start_col, 1)
  }
  if (ch == "]") {
    advance(lexer)
    return makeToken("RBRACKET", "]", start_line, start_col, 1)
  }

  // 알 수 없는 문자는 스킵
  advance(lexer)
  return makeToken("UNKNOWN", ch, start_line, start_col, 1)
}

// ============================================
// 11. 메인 토크나이저 함수
// ============================================

/**
 * 소스 코드를 토큰 배열로 변환
 */
fn tokenize(source) {
  let lexer = createLexer(source)

  while (lexer.pos < string_length(source)) {
    skipWhitespace(lexer)

    let ch = current(lexer)

    // 파일 끝
    if (ch == "") {
      break
    }

    // 식별자 또는 키워드
    if (isAlpha(ch) == 1) {
      let token = scanIdentifier(lexer)
      push(lexer.tokens, token)
      continue
    }

    // 숫자
    if (isDigit(ch) == 1) {
      let token = scanNumber(lexer)
      push(lexer.tokens, token)
      continue
    }

    // 문자열
    if (ch == "\"") {
      let token = scanString(lexer)
      push(lexer.tokens, token)
      continue
    }

    // 연산자 및 구두점
    let token = scanOperator(lexer)
    push(lexer.tokens, token)
  }

  // EOF 토큰 추가
  let eof_token = makeToken("EOF", "", lexer.line, lexer.col, 0)
  push(lexer.tokens, eof_token)

  return lexer.tokens
}

// ============================================
// 12. 토큰 표시 함수 (디버깅)
// ============================================

/**
 * 토큰을 문자열로 변환 (디버깅용)
 */
fn tokenToString(token) {
  let result = "["
  result = result + token.kind
  result = result + ": \""
  result = result + token.value
  result = result + "\" @"
  result = result + str(token.line)
  result = result + ":"
  result = result + str(token.col)
  result = result + "]"

  return result
}

/**
 * 토큰 배열을 출력 (디버깅용)
 */
fn printTokens(tokens) {
  let i = 0
  while (i < arr_len(tokens)) {
    let token = arr_get(tokens, i)
    println(tokenToString(token))
    i = i + 1
  }
}

// ════════════════════════════════════════════════════════════════════════════
// STAGE 2: PARSER (AST Generation)
// ════════════════════════════════════════════════════════════════════════════

/**
 * FreeLang Self-Hosting Parser (Agent 3 Implementation)
 *
 * 자체호스팅 파서 구현 - FreeLang으로 작성된 완전한 파서
 *
 * 목표:
 *   - Lexer 토큰을 AST로 변환
 *   - 재귀 하강 파싱 (Recursive Descent)
 *   - 모든 FreeLang 문법 지원
 *
 * AST 구조:
 *   { type: "...", data: {...}, children: [...] }
 *
 * 예시:
 *   let code = "fn add(a, b) { return a + b }"
 *   let tokens = tokenize(code)
 *   let ast = parseProgram(tokens)
 *   println(ast.data.functions.length)
 */

// ============================================
// 1. 파서 상태 관리
// ============================================

fn createParserState(tokens) {
  let state = {
    tokens: tokens,
    pos: 0,
    errors: []
  }
  return state
}

fn getCurrentToken(state) {
  let pos = state.pos
  let tokens = state.tokens
  let len = arr_len(tokens)

  if (pos < len) {
    return arr_get(tokens, pos)
  }

  // EOF token
  return { kind: "EOF", value: "", line: 1, col: 1 }
}

fn getPeekToken(state, offset) {
  let pos = state.pos + offset
  let tokens = state.tokens
  let len = arr_len(tokens)

  if (pos < len) {
    return arr_get(tokens, pos)
  }

  return { kind: "EOF", value: "", line: 1, col: 1 }
}

fn advanceParser(state) {
  state.pos = state.pos + 1
  return state
}

fn checkTokenKind(state, kind) {
  let tok = getCurrentToken(state)
  return tok.kind == kind
}

fn matchTokenKind(state, kind) {
  if (checkTokenKind(state, kind)) {
    let tok = getCurrentToken(state)
    advanceParser(state)
    return tok
  }
  return 0
}

fn consumeTokenKind(state, kind, errMsg) {
  if (checkTokenKind(state, kind)) {
    let tok = getCurrentToken(state)
    advanceParser(state)
    return tok
  }

  // Error
  arr_push(state.errors, errMsg)
  return 0
}

// ============================================
// 2. AST 노드 생성 헬퍼
// ============================================

fn makeASTNode(nodeType, data, children) {
  let node = {
    type: nodeType,
    data: data,
    children: children
  }
  return node
}

fn makeIdentifierNode(name) {
  return makeASTNode("Identifier", { name: name }, [])
}

fn makeLiteralNode(value, literalType) {
  return makeASTNode("Literal", { value: value, literalType: literalType }, [])
}

fn makeNumberNode(value) {
  return makeLiteralNode(value, "number")
}

fn makeStringNode(value) {
  return makeLiteralNode(value, "string")
}

fn makeBinaryOpNode(op, left, right) {
  return makeASTNode("BinaryOp", { op: op }, [left, right])
}

fn makeCallNode(callee, args) {
  let children = [callee]
  let i = 0
  while (i < arr_len(args)) {
    arr_push(children, arr_get(args, i))
    i = i + 1
  }
  return makeASTNode("Call", {}, children)
}

fn makeFunctionNode(name, params, body) {
  return makeASTNode("Function", { name: name, params: params }, [body])
}

fn makeLetNode(name, value) {
  return makeASTNode("Let", { name: name }, [value])
}

fn makeIfNode(condition, thenBody, elseBody) {
  let children = [condition, thenBody]
  if (elseBody) {
    arr_push(children, elseBody)
  }
  return makeASTNode("If", {}, children)
}

fn makeBlockNode(statements) {
  return makeASTNode("Block", {}, statements)
}

fn makeReturnNode(value) {
  let children = []
  if (value) {
    arr_push(children, value)
  }
  return makeASTNode("Return", {}, children)
}

// ============================================
// 3. 우선순위 및 연산자 처리
// ============================================

fn getOperatorPrecedence(op) {
  if (op == "||") {
    return 1
  }
  if (op == "&&") {
    return 2
  }
  if (op == "==" || op == "!=") {
    return 3
  }
  if (op == "<" || op == ">" || op == "<=" || op == ">=") {
    return 4
  }
  if (op == "+" || op == "-") {
    return 5
  }
  if (op == "*" || op == "/" || op == "%") {
    return 6
  }
  if (op == "^") {
    return 7
  }
  return 0
}

fn isBinaryOp(tok) {
  return getOperatorPrecedence(tok.value) > 0
}

// ============================================
// 4. Expression 파싱 (Recursive Descent)
// ============================================

fn parsePrimary(state) {
  let tok = getCurrentToken(state)

  // Number
  if (tok.kind == "NUMBER") {
    advanceParser(state)
    return makeNumberNode(tok.value)
  }

  // String
  if (tok.kind == "STRING") {
    advanceParser(state)
    return makeStringNode(tok.value)
  }

  // Identifier or function call
  if (tok.kind == "IDENT") {
    advanceParser(state)
    let name = tok.value

    // Check for function call
    if (checkTokenKind(state, "LPAREN")) {
      advanceParser(state)
      let args = []

      // Parse arguments
      while (!checkTokenKind(state, "RPAREN") && !checkTokenKind(state, "EOF")) {
        let arg = parseExpression(state)
        arr_push(args, arg)

        // Check for comma
        if (checkTokenKind(state, "COMMA")) {
          advanceParser(state)
        }
      }

      // Consume )
      consumeTokenKind(state, "RPAREN", "Expected )")

      return makeCallNode(makeIdentifierNode(name), args)
    }

    return makeIdentifierNode(name)
  }

  // Parenthesized expression
  if (tok.kind == "LPAREN") {
    advanceParser(state)
    let expr = parseExpression(state)
    consumeTokenKind(state, "RPAREN", "Expected )")
    return expr
  }

  // Error
  arr_push(state.errors, "Unexpected token: " + tok.kind)
  return 0
}

fn parseBinaryRight(state, left, minPrec) {
  let tok = getCurrentToken(state)
  let prec = getOperatorPrecedence(tok.value)

  if (prec == 0 || prec < minPrec) {
    return left
  }

  // Consume operator
  advanceParser(state)
  let op = tok.value

  // Parse right side
  let right = parsePrimary(state)

  // Check next operator
  let nextTok = getCurrentToken(state)
  let nextPrec = getOperatorPrecedence(nextTok.value)

  if (nextPrec > prec) {
    right = parseBinaryRight(state, right, prec + 1)
  }

  // Create binary node
  let binary = makeBinaryOpNode(op, left, right)

  // Continue chaining
  return parseBinaryRight(state, binary, minPrec)
}

fn parseExpression(state) {
  let left = parsePrimary(state)
  if (left == 0) {
    return 0
  }
  return parseBinaryRight(state, left, 0)
}

// ============================================
// 5. Statement 파싱
// ============================================

fn parseBlock(state) {
  // Consume {
  consumeTokenKind(state, "LBRACE", "Expected {")

  let statements = []

  // Parse statements until }
  while (!checkTokenKind(state, "RBRACE") && !checkTokenKind(state, "EOF")) {
    let stmt = parseStatement(state)
    if (stmt) {
      arr_push(statements, stmt)
    }
  }

  // Consume }
  consumeTokenKind(state, "RBRACE", "Expected }")

  return makeBlockNode(statements)
}

fn parseStatement(state) {
  let tok = getCurrentToken(state)

  // Let declaration
  if (tok.kind == "LET") {
    advanceParser(state)

    // Get variable name
    let idTok = consumeTokenKind(state, "IDENT", "Expected identifier")
    if (idTok == 0) {
      return 0
    }
    let name = idTok.value

    // Consume =
    consumeTokenKind(state, "ASSIGN", "Expected =")

    // Parse expression
    let value = parseExpression(state)

    // Optional semicolon
    if (checkTokenKind(state, "SEMICOLON")) {
      advanceParser(state)
    }

    return makeLetNode(name, value)
  }

  // Return statement
  if (tok.kind == "RETURN") {
    advanceParser(state)

    let value = 0
    if (!checkTokenKind(state, "SEMICOLON") && !checkTokenKind(state, "RBRACE")) {
      value = parseExpression(state)
    }

    // Optional semicolon
    if (checkTokenKind(state, "SEMICOLON")) {
      advanceParser(state)
    }

    return makeReturnNode(value)
  }

  // If statement
  if (tok.kind == "IF") {
    advanceParser(state)

    // Consume (
    consumeTokenKind(state, "LPAREN", "Expected (")
    let condition = parseExpression(state)
    consumeTokenKind(state, "RPAREN", "Expected )")

    // Parse then block
    let thenBlock = parseBlock(state)

    // Check for else
    let elseBlock = 0
    if (checkTokenKind(state, "ELSE")) {
      advanceParser(state)
      elseBlock = parseBlock(state)
    }

    return makeIfNode(condition, thenBlock, elseBlock)
  }

  // While loop
  if (tok.kind == "WHILE") {
    advanceParser(state)

    consumeTokenKind(state, "LPAREN", "Expected (")
    let condition = parseExpression(state)
    consumeTokenKind(state, "RPAREN", "Expected )")

    let body = parseBlock(state)

    return makeASTNode("While", {}, [condition, body])
  }

  // Block
  if (tok.kind == "LBRACE") {
    return parseBlock(state)
  }

  // Expression statement
  let expr = parseExpression(state)
  if (expr == 0) {
    return 0
  }

  // Optional semicolon
  if (checkTokenKind(state, "SEMICOLON")) {
    advanceParser(state)
  }

  return makeASTNode("ExprStmt", {}, [expr])
}

// ============================================
// 6. Function Declaration Parsing
// ============================================

fn parseFunctionDecl(state) {
  // Consume fn
  consumeTokenKind(state, "FN", "Expected fn")

  // Get function name
  let nameTok = consumeTokenKind(state, "IDENT", "Expected function name")
  if (nameTok == 0) {
    return 0
  }
  let name = nameTok.value

  // Parse parameters
  consumeTokenKind(state, "LPAREN", "Expected (")

  let params = []
  while (!checkTokenKind(state, "RPAREN") && !checkTokenKind(state, "EOF")) {
    let paramTok = consumeTokenKind(state, "IDENT", "Expected parameter name")
    if (paramTok == 0) {
      return 0
    }
    arr_push(params, paramTok.value)

    // Check for comma
    if (checkTokenKind(state, "COMMA")) {
      advanceParser(state)
    }
  }

  consumeTokenKind(state, "RPAREN", "Expected )")

  // Parse function body
  let body = parseBlock(state)

  return makeFunctionNode(name, params, body)
}

// ============================================
// 7. Module/Program Parsing
// ============================================

fn parseProgram(tokens) {
  let state = createParserState(tokens)
  let functions = []
  let variables = []

  // Parse top-level declarations
  while (!checkTokenKind(state, "EOF")) {
    let tok = getCurrentToken(state)

    // Function declaration
    if (tok.kind == "FN") {
      let fn = parseFunctionDecl(state)
      if (fn) {
        arr_push(functions, fn)
      }
    }
    // Variable declaration
    else if (tok.kind == "LET") {
      let stmt = parseStatement(state)
      if (stmt) {
        arr_push(variables, stmt)
      }
    }
    else {
      // Skip unknown tokens at module level
      advanceParser(state)
    }
  }

  // Return AST
  let ast = {
    type: "Program",
    functions: functions,
    variables: variables,
    errors: state.errors
  }

  return ast
}

// ============================================
// 8. Main Export
// ============================================

fn parseSelfHosted(code) {
  let tokens = tokenize(code)
  return parseProgram(tokens)
}

// ════════════════════════════════════════════════════════════════════════════
// STAGE 3: IR GENERATOR (Intermediate Representation)
// ════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────────
// FreeLang v2: Self-IR Generator (자체 IR 생성기)
// ─────────────────────────────────────────────────────────────────
//
// 목표: AST 객체를 받아서 IR 명령어 배열로 변환
// 전략: 단순 선형 순회 + 객체 리터럴 사용 (구조체 없음)
// 특징: 모든 함수는 v2 stdlib만 사용
//
// 사용 가능 함수:
//   - arr_push, arr_len, arr_get: 배열 조작
//   - map.new, map.set, map.get: 객체/맵 조작
//   - str: 숫자 → 문자열 변환
//

// ─────────────────────────────────────────────────────────────────
// 1. Generator 초기화
// ─────────────────────────────────────────────────────────────────

fn createGenerator() {
  return {
    insts: [],
    tempCount: 0
  }
}


// ─────────────────────────────────────────────────────────────────
// 2. 명령어 생성 헬퍼 함수들
// ─────────────────────────────────────────────────────────────────

// 일반 명령어 생성 (op + arg)
fn emit(gen, op, arg) {
  let inst = {}
  inst.op = op
  if (arg != 0) {
    inst.arg = arg
  }
  arr_push(gen.insts, inst)
  return gen
}

// PUSH 명령어 (상수값 스택에 올림)
fn emitPush(gen, val) {
  return emit(gen, "PUSH", val)
}

// STORE 명령어 (변수에 값 저장)
fn emitStore(gen, name) {
  return emit(gen, "STORE", name)
}

// LOAD 명령어 (변수값 스택에 올림)
fn emitLoad(gen, name) {
  return emit(gen, "LOAD", name)
}

// 산술 명령어
fn emitAdd(gen) {
  return emit(gen, "ADD", 0)
}

fn emitSub(gen) {
  return emit(gen, "SUB", 0)
}

fn emitMul(gen) {
  return emit(gen, "MUL", 0)
}

fn emitDiv(gen) {
  return emit(gen, "DIV", 0)
}

// 비교 명령어
fn emitEq(gen) {
  return emit(gen, "EQ", 0)
}

fn emitNeq(gen) {
  return emit(gen, "NEQ", 0)
}

fn emitLt(gen) {
  return emit(gen, "LT", 0)
}

fn emitGt(gen) {
  return emit(gen, "GT", 0)
}

fn emitLte(gen) {
  return emit(gen, "LTE", 0)
}

fn emitGte(gen) {
  return emit(gen, "GTE", 0)
}

// 문자열 명령어
fn emitStr(gen, val) {
  return emit(gen, "STR_NEW", val)
}

// 함수 호출 명령어
fn emitCall(gen, name) {
  return emit(gen, "CALL", name)
}

// 점프 명령어
fn emitJmp(gen, label) {
  return emit(gen, "JMP", label)
}

fn emitJmpNot(gen, label) {
  return emit(gen, "JMP_NOT", label)
}

// 라벨 명령어
fn emitLabel(gen, label) {
  return emit(gen, "LABEL", label)
}

// 반환 명령어
fn emitRet(gen) {
  return emit(gen, "RET", 0)
}

// 정지 명령어
fn emitHalt(gen) {
  return emit(gen, "HALT", 0)
}


// ─────────────────────────────────────────────────────────────────
// 3. 라벨 생성 헬퍼
// ─────────────────────────────────────────────────────────────────

fn newLabel(gen) {
  let label = "L" + str(gen.tempCount)
  gen.tempCount = gen.tempCount + 1
  return label
}


// ─────────────────────────────────────────────────────────────────
// 4. Expression 생성 함수
// ─────────────────────────────────────────────────────────────────

fn generateExpression(gen, expr) {
  if (expr == 0) {
    return gen
  }

  let exprType = expr.type

  // 숫자 리터럴: 42
  if (exprType == "NumberLiteral") {
    return emitPush(gen, expr.value)
  }

  // 문자열 리터럴: "hello"
  if (exprType == "StringLiteral") {
    return emitStr(gen, expr.value)
  }

  // 식별자: x
  if (exprType == "Identifier") {
    return emitLoad(gen, expr.name)
  }

  // 이항 연산: x + y
  if (exprType == "BinaryOp") {
    return generateBinaryOp(gen, expr)
  }

  // 함수 호출: println(x)
  if (exprType == "CallExpr") {
    return generateCallExpr(gen, expr)
  }

  return gen
}


// ─────────────────────────────────────────────────────────────────
// 5. BinaryOp 생성 함수 (x + y, x > y 등)
// ─────────────────────────────────────────────────────────────────

fn generateBinaryOp(gen, expr) {
  // 좌측 피연산자
  generateExpression(gen, expr.left)

  // 우측 피연산자
  generateExpression(gen, expr.right)

  // 연산자 명령어
  let op = expr.op

  if (op == "+") {
    return emitAdd(gen)
  }

  if (op == "-") {
    return emitSub(gen)
  }

  if (op == "*") {
    return emitMul(gen)
  }

  if (op == "/") {
    return emitDiv(gen)
  }

  if (op == "==") {
    return emitEq(gen)
  }

  if (op == "!=") {
    return emitNeq(gen)
  }

  if (op == "<") {
    return emitLt(gen)
  }

  if (op == ">") {
    return emitGt(gen)
  }

  if (op == "<=") {
    return emitLte(gen)
  }

  if (op == ">=") {
    return emitGte(gen)
  }

  return gen
}


// ─────────────────────────────────────────────────────────────────
// 6. CallExpr 생성 함수 (함수 호출)
// ─────────────────────────────────────────────────────────────────

fn generateCallExpr(gen, expr) {
  let args = expr.args
  let i = 0

  // 모든 인자 생성
  while (i < arr_len(args)) {
    let arg = arr_get(args, i)
    generateExpression(gen, arg)
    i = i + 1
  }

  // CALL 명령어
  let funcName = expr.callee.name
  return emitCall(gen, funcName)
}


// ─────────────────────────────────────────────────────────────────
// 7. Statement 생성 함수들
// ─────────────────────────────────────────────────────────────────

fn generateStatement(gen, stmt) {
  if (stmt == 0) {
    return gen
  }

  let stmtType = stmt.type

  // let x = 10
  if (stmtType == "LetDecl") {
    return generateLetDecl(gen, stmt)
  }

  // return x
  if (stmtType == "ReturnStmt") {
    return generateReturnStmt(gen, stmt)
  }

  // if (x > 5) { ... } else { ... }
  if (stmtType == "IfStmt") {
    return generateIfStmt(gen, stmt)
  }

  // while (x < 10) { ... }
  if (stmtType == "WhileStmt") {
    return generateWhileStmt(gen, stmt)
  }

  // println(x)
  if (stmtType == "ExpressionStmt") {
    return generateExpression(gen, stmt.expr)
  }

  return gen
}


// ─────────────────────────────────────────────────────────────────
// 8. Let 선언 생성 (let x = 10)
// ─────────────────────────────────────────────────────────────────

fn generateLetDecl(gen, stmt) {
  // 초기값 계산
  generateExpression(gen, stmt.value)

  // 변수에 저장
  return emitStore(gen, stmt.name)
}


// ─────────────────────────────────────────────────────────────────
// 9. Return 문 생성 (return x)
// ─────────────────────────────────────────────────────────────────

fn generateReturnStmt(gen, stmt) {
  // 반환값 계산 (있으면)
  if (stmt.value != 0) {
    generateExpression(gen, stmt.value)
  }

  // RET 명령어
  return emitRet(gen)
}


// ─────────────────────────────────────────────────────────────────
// 10. If/Else 문 생성
// ─────────────────────────────────────────────────────────────────

fn generateIfStmt(gen, stmt) {
  let elseLabel = newLabel(gen)
  let endLabel = newLabel(gen)

  // 조건 계산
  generateExpression(gen, stmt.condition)

  // 거짓이면 else로 점프
  emitJmpNot(gen, elseLabel)

  // then 블록
  let thenBody = stmt.then
  let i = 0
  while (i < arr_len(thenBody)) {
    let s = arr_get(thenBody, i)
    generateStatement(gen, s)
    i = i + 1
  }

  // 끝으로 점프
  emitJmp(gen, endLabel)

  // else 라벨
  emitLabel(gen, elseLabel)

  // else 블록 (있으면)
  let elseBody = stmt.else
  if (elseBody != 0) {
    let j = 0
    while (j < arr_len(elseBody)) {
      let s = arr_get(elseBody, j)
      generateStatement(gen, s)
      j = j + 1
    }
  }

  // 끝 라벨
  emitLabel(gen, endLabel)

  return gen
}


// ─────────────────────────────────────────────────────────────────
// 11. While 루프 생성
// ─────────────────────────────────────────────────────────────────

fn generateWhileStmt(gen, stmt) {
  let loopLabel = newLabel(gen)
  let endLabel = newLabel(gen)

  // 루프 시작 라벨
  emitLabel(gen, loopLabel)

  // 조건 계산
  generateExpression(gen, stmt.condition)

  // 거짓이면 끝으로 점프
  emitJmpNot(gen, endLabel)

  // 루프 본체
  let body = stmt.body
  let i = 0
  while (i < arr_len(body)) {
    let s = arr_get(body, i)
    generateStatement(gen, s)
    i = i + 1
  }

  // 루프 시작으로 점프
  emitJmp(gen, loopLabel)

  // 끝 라벨
  emitLabel(gen, endLabel)

  return gen
}


// ─────────────────────────────────────────────────────────────────
// 12. 메인 IR 생성 함수
// ─────────────────────────────────────────────────────────────────

fn generateIR(ast) {
  let gen = createGenerator()

  // AST 본체의 모든 statement 처리
  let body = ast.body
  let i = 0
  while (i < arr_len(body)) {
    let stmt = arr_get(body, i)
    generateStatement(gen, stmt)
    i = i + 1
  }

  // 프로그램 종료
  emitHalt(gen)

  return gen.insts
}


// ─────────────────────────────────────────────────────────────────
// 13. 유틸리티: IR 출력 (디버깅용)
// ─────────────────────────────────────────────────────────────────

fn irToString(ir) {
  let result = ""
  let i = 0
  while (i < arr_len(ir)) {
    let inst = arr_get(ir, i)
    let line = inst.op
    if (inst.arg != 0) {
      line = line + " " + str(inst.arg)
    }
    result = result + line + "\n"
    i = i + 1
  }
  return result
}

fn printIR(ir) {
  println(irToString(ir))
}


// ─────────────────────────────────────────────────────────────────
// 14. 테스트: 기본 식 생성
// ─────────────────────────────────────────────────────────────────

fn testBasicExpr() {
  println("=== Test 1: Basic Expression (3 + 4) ===")

  let ast = {
    body: [
      {
        type: "ExpressionStmt",
        expr: {
          type: "BinaryOp",
          op: "+",
          left: { type: "NumberLiteral", value: 3 },
          right: { type: "NumberLiteral", value: 4 }
        }
      }
    ]
  }

  let ir = generateIR(ast)
  printIR(ir)
  println("")
}


// ─────────────────────────────────────────────────────────────────
// 15. 테스트: 변수 선언 + 반환
// ─────────────────────────────────────────────────────────────────

fn testLetReturn() {
  println("=== Test 2: Let Declaration + Return ===")

  let ast = {
    body: [
      {
        type: "LetDecl",
        name: "x",
        value: { type: "NumberLiteral", value: 42 }
      },
      {
        type: "ReturnStmt",
        value: { type: "Identifier", name: "x" }
      }
    ]
  }

  let ir = generateIR(ast)
  printIR(ir)
  println("")
}


// ─────────────────────────────────────────────────────────────────
// 16. 테스트: If/Else 문
// ─────────────────────────────────────────────────────────────────

fn testIfStmt() {
  println("=== Test 3: If/Else Statement ===")

  let ast = {
    body: [
      {
        type: "LetDecl",
        name: "x",
        value: { type: "NumberLiteral", value: 10 }
      },
      {
        type: "IfStmt",
        condition: {
          type: "BinaryOp",
          op: ">",
          left: { type: "Identifier", name: "x" },
          right: { type: "NumberLiteral", value: 5 }
        },
        then: [
          {
            type: "ExpressionStmt",
            expr: { type: "NumberLiteral", value: 100 }
          }
        ],
        else: [
          {
            type: "ExpressionStmt",
            expr: { type: "NumberLiteral", value: 200 }
          }
        ]
      }
    ]
  }

  let ir = generateIR(ast)
  printIR(ir)
  println("")
}


// ─────────────────────────────────────────────────────────────────
// 17. 테스트: While 루프
// ─────────────────────────────────────────────────────────────────

fn testWhileStmt() {
  println("=== Test 4: While Loop ===")

  let ast = {
    body: [
      {
        type: "LetDecl",
        name: "i",
        value: { type: "NumberLiteral", value: 0 }
      },
      {
        type: "WhileStmt",
        condition: {
          type: "BinaryOp",
          op: "<",
          left: { type: "Identifier", name: "i" },
          right: { type: "NumberLiteral", value: 10 }
        },
        body: [
          {
            type: "ExpressionStmt",
            expr: {
              type: "BinaryOp",
              op: "+",
              left: { type: "Identifier", name: "i" },
              right: { type: "NumberLiteral", value: 1 }
            }
          }
        ]
      }
    ]
  }

  let ir = generateIR(ast)
  printIR(ir)
  println("")
}


// ─────────────────────────────────────────────────────────────────
// 18. 테스트: 함수 호출
// ─────────────────────────────────────────────────────────────────

fn testCallExpr() {
  println("=== Test 5: Function Call ===")

  let ast = {
    body: [
      {
        type: "ExpressionStmt",
        expr: {
          type: "CallExpr",
          callee: { name: "println" },
          args: [
            { type: "NumberLiteral", value: 42 }
          ]
        }
      }
    ]
  }

  let ir = generateIR(ast)
  printIR(ir)
  println("")
}


// ─────────────────────────────────────────────────────────────────
