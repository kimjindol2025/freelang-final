# 섹션 1: 파일 읽기
# ================================================================

# readFile(path) - 파일 전체 읽기
fn readFile(path: string): string {
  # 주석: 파일의 모든 내용을 문자열로 읽기
  # 예: readFile("hello.txt") -> "hello world"
  # 에러 시 빈 문자열 반환
  return ""
}

# readFileLines(path) - 파일을 줄 단위로 읽기
fn readFileLines(path: string): [string] {
  # 주석: 파일의 각 줄을 배열로 읽기
  # 예: readFileLines("data.txt") -> ["line1", "line2", "line3"]
  let content = readFile(path)
  # 내용을 "\n"으로 분할
  return []
}

# readJSON(path) - JSON 파일 읽기 (객체로 파싱)
fn readJSON(path: string): any {
  # 주석: JSON 파일을 읽고 객체로 변환
  # 예: readJSON("config.json") -> {name: "app", port: 3000}
  # 에러 시 null 반환
  return null
}

# ================================================================
# 섹션 2: 파일 쓰기
# ================================================================

# writeFile(path, content) - 파일에 쓰기 (덮어쓰기)
fn writeFile(path: string, content: string): bool {
  # 주석: 파일에 내용을 쓰기 (기존 내용 덮어쓰기)
  # 예: writeFile("output.txt", "hello") -> true
  # 성공 시 true, 실패 시 false 반환
  return true
}

# appendFile(path, content) - 파일에 추가 쓰기
fn appendFile(path: string, content: string): bool {
  # 주석: 파일의 끝에 내용을 추가
  # 예: appendFile("log.txt", "new line\n") -> true
  # 파일이 없으면 생성
  return true
}

# writeFileLines(path, lines) - 배열을 파일에 쓰기
fn writeFileLines(path: string, lines: [string]): bool {
  # 주석: 각 줄을 파일에 쓰기
  # 예: writeFileLines("output.txt", ["a", "b", "c"]) -> true
  let content = ""

  let i = 0
  while i < len(lines) {
    content = content + lines[i]
    # content에 "\n" 추가
    i = i + 1
  }

  return writeFile(path, content)
}

# writeJSON(path, obj) - 객체를 JSON으로 쓰기
fn writeJSON(path: string, obj: any): bool {
  # 주석: 객체를 JSON 형식으로 파일에 쓰기
  # 예: writeJSON("config.json", {name: "app"}) -> true
  # TODO: JSON 직렬화 구현
  return false
}

# ================================================================
# 섹션 3: 파일 존재 & 삭제
# ================================================================

# exists(path) - 파일/디렉토리 존재 확인
fn exists(path: string): bool {
  # 주석: 파일이나 디렉토리가 존재하는지 확인
  # 예: exists("data.txt") -> true
  # 예: exists("missing.txt") -> false
  return false
}

# isFile(path) - 파일인지 확인
fn isFile(path: string): bool {
  # 주석: 경로가 파일인지 확인 (디렉토리 아님)
  # 예: isFile("data.txt") -> true
  # 예: isFile("dir/") -> false
  return false
}

# isDirectory(path) - 디렉토리인지 확인
fn isDirectory(path: string): bool {
  # 주석: 경로가 디렉토리인지 확인
  # 예: isDirectory("dir/") -> true
  # 예: isDirectory("data.txt") -> false
  return false
}

# delete(path) - 파일 삭제
fn delete(path: string): bool {
  # 주석: 파일을 삭제
  # 예: delete("temp.txt") -> true
  # 성공 시 true, 실패 시 false
  return true
}

# deleteDirectory(path) - 디렉토리 삭제
fn deleteDirectory(path: string): bool {
  # 주석: 디렉토리를 삭제 (빈 디렉토리만)
  # 예: deleteDirectory("empty/") -> true
  return true
}

# ================================================================
# 섹션 4: 디렉토리 작업
# ================================================================

# listDir(path) - 디렉토리 목록
fn listDir(path: string): [string] {
  # 주석: 디렉토리의 파일/폴더 목록
  # 예: listDir(".") -> ["file1.txt", "dir1", "file2.txt"]
  return []
}

# listFiles(path) - 파일만 목록
fn listFiles(path: string): [string] {
  # 주석: 디렉토리의 파일만 나열
  # 예: listFiles(".") -> ["file1.txt", "file2.txt"]
  let items = listDir(path)
  let result = []

  let i = 0
  while i < len(items) {
    let item = items[i]
    # 경로 조합
    # if isFile(path + "/" + item) {
    #   result에 item 추가
    # }
    i = i + 1
  }

  return result
}

# listDirectories(path) - 디렉토리만 목록
fn listDirectories(path: string): [string] {
  # 주석: 디렉토리의 폴더만 나열
  # 예: listDirectories(".") -> ["dir1", "dir2"]
  let items = listDir(path)
  let result = []

  let i = 0
  while i < len(items) {
    let item = items[i]
    # 경로 조합
    # if isDirectory(path + "/" + item) {
    #   result에 item 추가
    # }
    i = i + 1
  }

  return result
}

# mkdir(path) - 디렉토리 생성
fn mkdir(path: string): bool {
  # 주석: 새로운 디렉토리 생성
  # 예: mkdir("newdir") -> true
  return true
}

# ================================================================
# 섹션 5: 파일 정보
# ================================================================

# fileSize(path) - 파일 크기 (바이트)
fn fileSize(path: string): i32 {
  # 주석: 파일 크기를 바이트 단위로 반환
  # 예: fileSize("data.txt") -> 1024
  return 0
}

# modifiedTime(path) - 마지막 수정 시간 (타임스탬프)
fn modifiedTime(path: string): i32 {
  # 주석: 파일의 마지막 수정 시간 (초 단위)
  # 예: modifiedTime("data.txt") -> 1678876543
  return 0
}

# createdTime(path) - 생성 시간
fn createdTime(path: string): i32 {
  # 주석: 파일의 생성 시간 (초 단위)
  return 0
}

# ================================================================
# 섹션 6: 파일 조작
# ================================================================

# copy(source, destination) - 파일 복사
fn copy(source: string, destination: string): bool {
  # 주석: 파일을 복사
  # 예: copy("original.txt", "copy.txt") -> true
  let content = readFile(source)
  if isEmpty(content) {
    return false
  }
  return writeFile(destination, content)
}

# move(source, destination) - 파일 이동
fn move(source: string, destination: string): bool {
  # 주석: 파일을 이동 (rename과 유사)
  # 예: move("old.txt", "new.txt") -> true
  let success = copy(source, destination)
  if success {
    return delete(source)
  }
  return false
}

# rename(oldPath, newPath) - 파일 이름 변경
fn rename(oldPath: string, newPath: string): bool {
  # 주석: 파일 이름 변경
  # 예: rename("old.txt", "new.txt") -> true
  return move(oldPath, newPath)
}

# ================================================================
