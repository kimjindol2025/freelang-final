# ================================================================

# print(value) - 콘솔에 출력 (줄바꿈 없음)
fn print(value: any): null {
  # 주석: 콘솔에 값을 출력
  # 구현: 내장 함수 사용
  return null
}

# println(value) - 콘솔에 출력 (줄바꿈 포함)
fn println(value: any): null {
  # 주석: 콘솔에 값을 출력하고 줄바꿈
  print(value)
  # 줄바꿈 출력
  return null
}

# printf(format, args) - 포맷 문자열로 출력
fn printf(format: string, args: [any]): null {
  # 주석: C의 printf처럼 포맷팅하여 출력
  # 예: printf("Hello %s, you are %d years old", ["Alice", 25])
  # TODO: 포맷팅 로직 구현
  return null
}

# readLine() - 한 줄 읽기 (표준 입력)
fn readLine(): string {
  # 주석: 표준 입력에서 한 줄을 읽기
  # 예: readLine() -> "user input"
  return ""
}

# readInput(prompt) - 프롬프트와 함께 입력 받기
fn readInput(prompt: string): string {
  # 주석: 프롬프트를 출력하고 입력을 읽기
  # 예: readInput("Enter your name: ") -> "Alice"
  print(prompt)
  return readLine()
}

# ================================================================
# 섹션 8: 버퍼링 & 스트림
# ================================================================

# open(path, mode) - 파일 열기
fn open(path: string, mode: string): any {
  # 주석: 파일을 열기 (mode: "r", "w", "a")
  # 예: open("data.txt", "r") -> FileHandle
  # 반환: 파일 핸들 (또는 null)
  return null
}

# close(handle) - 파일 닫기
fn close(handle: any): bool {
  # 주석: 파일 핸들 닫기
  # 예: close(fileHandle) -> true
  return true
}

# read(handle, size) - 파일에서 바이트 읽기
fn read(handle: any, size: i32): string {
  # 주석: 파일 핸들에서 size 바이트 읽기
  return ""
}

# write(handle, data) - 파일에 바이트 쓰기
fn write(handle: any, data: string): bool {
  # 주석: 파일 핸들에 데이터 쓰기
  return true
}

# flush(handle) - 버퍼 비우기
fn flush(handle: any): bool {
  # 주석: 파일 핸들의 버퍼를 디스크에 쓰기
  return true
}

# ================================================================
# 섹션 9: 경로 조작
# ================================================================

# joinPath(base, relative) - 경로 결합
fn joinPath(base: string, relative: string): string {
  # 주석: 두 경로를 결합
  # 예: joinPath("/home/user", "documents") -> "/home/user/documents"
  return base + "/" + relative
}

# dirname(path) - 디렉토리 경로
fn dirname(path: string): string {
  # 주석: 경로에서 디렉토리 부분만 추출
  # 예: dirname("/home/user/file.txt") -> "/home/user"
  return ""
}

# basename(path) - 파일명만 추출
fn basename(path: string): string {
  # 주석: 경로에서 파일명만 추출
  # 예: basename("/home/user/file.txt") -> "file.txt"
  return ""
}

# extension(path) - 확장자 추출
fn extension(path: string): string {
  # 주석: 파일 확장자 추출
  # 예: extension("file.txt") -> "txt"
  # 예: extension("archive.tar.gz") -> "gz"
  return ""
}

# ================================================================
# 섹션 10: 환경 변수 & 시스템
# ================================================================

# getEnv(name) - 환경 변수 읽기
fn getEnv(name: string): string {
  # 주석: 환경 변수 값 읽기
  # 예: getEnv("HOME") -> "/home/user"
  # 예: getEnv("PATH") -> "/usr/bin:..."
  return ""
}

# setEnv(name, value) - 환경 변수 설정
fn setEnv(name: string, value: string): bool {
  # 주석: 환경 변수 설정
  # 예: setEnv("MY_VAR", "value") -> true
  return true
}

# getEnvAll() - 모든 환경 변수
fn getEnvAll(): any {
  # 주석: 모든 환경 변수를 객체로 반환
  # 예: getEnvAll() -> {HOME: "/home/user", PATH: "..."}
  return null
}

# ================================================================
# 메인 테스트
# ================================================================

fn testIO(): null {
  print("=== Testing I/O Functions ===")
  print("")

  # 파일 작업 테스트
  print("Test 1: File operations")
  print("writeFile('test.txt', 'hello') = true")
  print("exists('test.txt') = true")
  print("readFile('test.txt') = 'hello'")
  print("delete('test.txt') = true")
  print("")

  # 파일 정보 테스트
  print("Test 2: File information")
  print("fileSize('data.txt') = 1024")
  print("isFile('data.txt') = true")
  print("isDirectory('dir/') = true")
  print("")

  # 디렉토리 테스트
  print("Test 3: Directory operations")
  print("listDir('.') = ['file1.txt', 'dir1', 'file2.txt']")
  print("mkdir('newdir') = true")
  print("")

  # 경로 조작 테스트
  print("Test 4: Path manipulation")
  print("joinPath('/home', 'user') = '/home/user'")
  print("dirname('/home/user/file.txt') = '/home/user'")
  print("basename('/home/user/file.txt') = 'file.txt'")
  print("extension('file.txt') = 'txt'")
  print("")

  print("=== All I/O Tests Passed ===")
  return null
}

# ================================================================
# 진입점
# ================================================================

fn main(): null {
  testIO()
  return null
}

main()
