// ============================================
// 예제 (Phase 1 테스트)
// ============================================

fn main(): void {
  // 테스트 1: 기본 assert
  describe("Basic Assertions", fn(): void {
    it("should pass", fn(): void {
      assert_true(true, "true는 true")
    })

    it("should fail correctly", fn(): void {
      assert_false(false, "false는 false")
    })

    it("should compare integers", fn(): void {
      assert_eq(5, 5, "5 == 5")
      assert_eq(10, 10, "10 == 10")
    })

    it("should compare strings", fn(): void {
      assert_str_eq("hello", "hello", "hello == hello")
      assert_str_eq("", "", "empty == empty")
    })
  })

  // 테스트 2: 심볼 테이블 예제
  describe("Symbol Table Example", fn(): void {
    it("should declare variable", fn(): void {
      // 예제: 심볼 테이블에 변수 저장
      assert_true(true, "변수 선언 성공")
    })

    it("should lookup variable", fn(): void {
      assert_true(true, "변수 조회 성공")
    })

    it("should handle scope", fn(): void {
      assert_true(true, "스코프 처리 성공")
    })
  })

  // 테스트 3: 의미 분석 예제
  describe("Semantic Analyzer Example", fn(): void {
    it("should detect type mismatch", fn(): void {
      // 예제: 타입 불일치 감지
      assert_true(true, "타입 체크 성공")
    })

    it("should verify function signature", fn(): void {
      assert_true(true, "함수 시그니처 검증 성공")
    })
  })

  // 테스트 4: IR 생성 예제
  describe("IR Generator Example", fn(): void {
    it("should generate basic IR", fn(): void {
      assert_true(true, "기본 IR 생성 성공")
    })

    it("should handle control flow", fn(): void {
      assert_true(true, "제어 흐름 처리 성공")
    })
  })

  // 최종 결과 출력
  print_summary()
}
