 */
fn os_time(): i64 {
  // 시뮬레이션 (실제로는 OS API 호출)
  return 0
}

// ============================================
// 테스트 함수
// ============================================

/**
 * test_parse_source(): void
 * parse_source() 함수 테스트
 * - Lexer + Parser 파이프라인 동작 확인
 */
fn test_parse_source(): void {
  println("")
  println("🧪 Testing parse_source()...")
  println("")

  // Test 1: 간단한 변수 선언
  let source1 = "let x = 42"
  var result1 = parse_source(source1)
  if result1.success {
    println("✓ Test 1: Simple variable declaration parsed")
    if result1.ast.body.length() > 0 {
      println("  AST body length: " + str(result1.ast.body.length()))
    }
  } else {
    println("✗ Test 1 failed: " + result1.error_msg)
  }

  // Test 2: 함수 정의
  let source2 = "fn add(x: i32, y: i32): i32 { return x + y; }"
  var result2 = parse_source(source2)
  if result2.success {
    println("✓ Test 2: Function declaration parsed")
  } else {
    println("✗ Test 2 failed: " + result2.error_msg)
  }

  // Test 3: 복합 프로그램
  let source3 = "let x = 10; if x > 5 { println(x); }"
  var result3 = parse_source(source3)
  if result3.success {
    println("✓ Test 3: Complex program parsed")
  } else {
    println("✗ Test 3 failed: " + result3.error_msg)
  }

  println("")
}

/**
 * test_analyze_program(): void
 * analyze_program() 함수 테스트
 * - Semantic analyzer 동작 확인
 */
fn test_analyze_program(): void {
  println("")
  println("🧪 Testing analyze_program()...")
  println("")

  // 먼저 AST를 파싱
  let source = "let x = 5; let y = x + 3;"
  var parser_result = parse_source(source)

  if !parser_result.success {
    println("✗ Parser failed: " + parser_result.error_msg)
    return
  }

  // Analyzer 생성
  var analyzer = new_analyzer()

  // 분석 수행
  let analysis_ok = analyze_program(analyzer, parser_result.ast)

  if analysis_ok {
    println("✓ Semantic analysis completed successfully")
    println("  Error count: " + str(analyzer.errors.length()))
  } else {
    println("✗ Semantic analysis failed")
    let i = 0
    while i < analyzer.errors.length() {
      println("  Error: " + analyzer.errors[i].message)
      i = i + 1
    }
  }

  println("")
}

/**
 * test_generate_ir(): void
 * generate_ir_from_ast() 함수 테스트
 * - IR 생성 동작 확인
 */
fn test_generate_ir(): void {
  println("")
  println("🧪 Testing generate_ir_from_ast()...")
  println("")

  // 먼저 AST를 파싱
  let source = "let x = 5; let y = 10;"
  var parser_result = parse_source(source)

  if !parser_result.success {
    println("✗ Parser failed: " + parser_result.error_msg)
    return
  }

  // IR Generator 생성
  var gen = new_ir_generator()

  // IR 생성
  generate_ir_from_ast(gen, parser_result.ast)

  if gen.program.blocks.length() > 0 {
    println("✓ IR generation completed successfully")
    println("  Basic blocks: " + str(gen.program.blocks.length()))
    println("  Temp vars: " + str(gen.program.temp_count))
  } else {
    println("⚠️  IR generation produced empty program")
  }

  println("")
}

/**
 * test_pipeline_integration(): void
 * 전체 파이프라인 통합 테스트
 */
fn test_pipeline_integration(): void {
  println("")
  println("🧪 Testing complete pipeline...")
  println("")

  let source = "let x = 42; let y = x + 8;"

  println("Input: " + source)
  println("")

  // Step 1: Parse
  println("Step 1: Parsing...")
  var parser_result = parse_source(source)
  if parser_result.success {
    println("✓ Parsing succeeded")
  } else {
    println("✗ Parsing failed: " + parser_result.error_msg)
    return
  }

  // Step 2: Analyze
  println("Step 2: Semantic analysis...")
  var analyzer = new_analyzer()
  let analysis_ok = analyze_program(analyzer, parser_result.ast)
  if analysis_ok {
    println("✓ Analysis succeeded")
  } else {
    println("✗ Analysis failed")
  }

  // Step 3: Generate IR
  println("Step 3: IR generation...")
  var gen = new_ir_generator()
  generate_ir_from_ast(gen, parser_result.ast)
  println("✓ IR generation completed")

  println("")
  println("✅ Pipeline integration test passed")
  println("")
}

