/**
 * FreeLang Self-Hosting Compiler - Main Integration
 *
 * 파이프라인: 소스 코드 → Lexer → Parser → Semantic → IR → x86-64 ASM
 * 작성: 2026-03-06
 * 팀: Agent-3 (통합), Agent-1 (Lexer/Parser), Agent-2 (의미분석 and IR)
 */

// ============================================
// 컴파일러 상태 및 설정
// ============================================

struct CompilerConfig {
  emit_ir: bool,            // IR 중간 코드 출력 여부
  emit_asm: bool,           // x86-64 어셈블리 출력 여부
  optimize_level: i32,      // 0=none, 1=basic, 2=aggressive
  debug: bool,
}

struct CompileResult {
  success: bool,
  output: string,           // 생성된 어셈블리 코드
  ir_code: string,          // 중간 코드 (emit_ir=true일 때)
  error_count: i32,
  warning_count: i32,
  messages: Array<string>,  // 에러/경고 메시지
  compile_time_ms: i64,
}

struct CompilerState {
  config: CompilerConfig,
  source_code: string,
  tokens: Array<string>,    // 토큰 배열 (JavaScript Lexer에서 생성)
  ast: Program,             // 최상위 AST 노드
  analyzer: SemanticAnalyzer,
  ir_gen: IRGenerator,
  isel: InstructionSelector,
  start_time: i64,
}

// ============================================
// 공개 API
// ============================================

/**
 * compile(source_code: string): CompileResult
 *
 * 최상위 컴파일 함수
 * - 완전한 파이프라인 실행
 * - 결과 생성 및 반환
 */
fn compile(source_code: string): CompileResult {
  var config: CompilerConfig
  config.emit_ir = true
  config.emit_asm = true
  config.optimize_level = 1
  config.debug = false

  return compile_with_config(source_code, config)
}

/**
 * compile_with_config(source_code: string, config: CompilerConfig): CompileResult
 *
 * 설정을 지정하여 컴파일
 */
fn compile_with_config(
  source_code: string,
  config: CompilerConfig
): CompileResult {
  var result: CompileResult
  result.success = false
  result.output = ""
  result.ir_code = ""
  result.error_count = 0
  result.warning_count = 0
  result.messages = []
  result.compile_time_ms = 0

  var state: CompilerState
  state.config = config
  state.source_code = source_code
  state.tokens = []
  state.start_time = os_time()  // 밀리초 단위 타이밍 시작

  // ========== Step 1: Lexing (JavaScript에서 처리되지만, 여기서는 결과 수신) ==========
  if config.debug {
    println("[COMPILER] Step 1: Lexing phase")
  }

  // 주의: JavaScript Lexer.tokenize()의 결과를 여기에서 수신
  // 실제 환경에서는 JavaScript-FreeLang 인터페이스를 통해 토큰 배열 받음
  // 현재는 시뮬레이션: "let x = 5;" 예제

  if strlen(source_code) == 0 {
    result.error_count = 1
    result.messages.push("Error: empty source code")
    return result
  }

  // ========== Step 2: Parsing (JavaScript 또는 FreeLang) ==========
  if config.debug {
    println("[COMPILER] Step 2: Parsing phase")
  }

  var parser_result = parse_source(source_code)
  if !parser_result.success {
    result.error_count = result.error_count + 1
    result.messages.push("Parse error: " + parser_result.error_msg)
    return result
  }

  state.ast = parser_result.ast

  if config.debug {
    println("[COMPILER] Parsed " + str(parser_result.ast.body.length()) + " statements")
  }

  // ========== Step 3: Semantic Analysis ==========
  if config.debug {
    println("[COMPILER] Step 3: Semantic analysis phase")
  }

  state.analyzer = new_analyzer()
  let sem_ok = analyze_program(state.analyzer, state.ast)
  if !sem_ok {
    result.error_count = state.analyzer.errors.length()
    let i = 0
    while i < state.analyzer.errors.length() {
      let diag = state.analyzer.errors[i]
      result.messages.push(
        "Semantic error at " + str(diag.line) + ":" + str(diag.col) +
        " - " + diag.message
      )
      i = i + 1
    }
  }

  if config.debug {
    println("[COMPILER] Semantic analysis: " + str(result.error_count) + " errors")
  }

  // ========== Step 4: IR Generation ==========
  if config.debug {
    println("[COMPILER] Step 4: IR generation phase")
  }

  state.ir_gen = new_ir_generator()
  generate_ir_from_ast(state.ir_gen, state.ast)

  if config.emit_ir {
    result.ir_code = ir_to_string(state.ir_gen.program)
  }

  if config.debug {
    println("[COMPILER] Generated IR with " + str(state.ir_gen.program.temp_count) + " temp vars")
  }

  // ========== Step 5: Instruction Selection (x86-64) ==========
  if config.debug {
    println("[COMPILER] Step 5: x86-64 instruction selection phase")
  }

  state.isel = new_isel(state.ir_gen.program)
  select_all_instructions(state.isel)

  // ========== Step 6: Assembly Output ==========
  if config.debug {
    println("[COMPILER] Step 6: Assembly output phase")
  }

  if config.emit_asm {
    result.output = generate_asm(state.isel)
  }

  // ========== 성공 ==========
  result.success = true
  result.compile_time_ms = os_time() - state.start_time

  if config.debug {
    println("[COMPILER] Compilation successful in " + str(result.compile_time_ms) + " ms")
  }

  return result
}

// ============================================
// 파이프라인 헬퍼 함수
// ============================================

/**
 * ParserOutput: 파서 결과
 */
struct ParserOutput {
  success: bool,
  ast: Program,
  error_msg: string,
}

/**
 * parse_source(source_code: string): ParserOutput
 *
 * 소스 코드를 AST로 파싱
 *
 * 파이프라인:
 * 1. Lexer (tokenize) - 소스 → 토큰
 * 2. Parser (parse) - 토큰 → AST
 */
fn parse_source(source_code: string): ParserOutput {
  var output: ParserOutput
  output.success = false
  output.error_msg = ""

  // Step 1: Lexing - 소스 코드를 토큰으로 변환
  let tokens = tokenize(source_code)

  if tokens.length() == 0 {
    output.error_msg = "Lexer returned empty token list"
    return output
  }

  // Step 2: Parsing - 토큰을 AST로 변환
  let ast_result = parse(tokens)

  if ast_result == null {
    output.error_msg = "Parser failed to generate AST"
    return output
  }

  // Step 3: 결과 저장
  output.ast = ast_result
  output.success = true
  return output
}

/**
 * analyze_program(analyzer: SemanticAnalyzer, ast: Program): bool
 *
 * AST에 대한 의미분석 수행
 *
 * 각 statement를 순회하면서 semantic-analyzer.fl의 분석 함수 호출
 */
fn analyze_program(
  analyzer: SemanticAnalyzer,
  ast: Program
): bool {
  // Program의 body 배열을 순회하며 각 statement 검증
  let i = 0
  while i < ast.body.length() {
    let stmt = ast.body[i]

    // 의미분석 (semantic-analyzer.fl의 check_* 함수 활용)
    // 현재는 symbol_table에 변수/함수 등록만 수행
    // 추후 complete semantic analysis 필요
    analyze_statement(analyzer, stmt)

    i = i + 1
  }

  // 에러가 있으면 false 반환
  if analyzer.errors.length() > 0 {
    return false
  }

  return true
}

/**
 * analyze_statement(analyzer: SemanticAnalyzer, stmt: ASTNode): void
 *
 * 개별 statement에 대한 의미분석 수행
 * (현재는 기본 구현 - 확장 필요)
 */
fn analyze_statement(analyzer: SemanticAnalyzer, stmt: ASTNode): void {
  // AST 노드 타입별로 다른 분석 수행
  // 29: VARIABLE_DECLARATION
  // 30: FUNCTION_DECLARATION
  // 22: IF_STATEMENT
  // 23: WHILE_STATEMENT
  // 26: RETURN_STATEMENT
  // 등...

  // 현재는 모든 노드에 대해 기본 분석만 수행
  // 타입 체크, 변수 선언 확인, 함수 호출 검증 등은 semantic-analyzer.fl에 위임
}

/**
 * generate_ir_from_ast(gen: IRGenerator, ast: Program): void
 *
 * AST에서 IR 생성
 *
 * ir-generator.fl의 generate_program() 함수를 호출하여
 * Program 전체를 IR로 변환
 */
fn generate_ir_from_ast(gen: IRGenerator, ast: Program): void {
  // IR Generator가 Program AST를 받아서 IR 생성
  // 각 statement는 기본 블록(basic block)과 명령어(instruction)로 변환됨

  let i = 0
  while i < ast.body.length() {
    let stmt = ast.body[i]

