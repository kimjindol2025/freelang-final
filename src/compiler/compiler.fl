}

/**
 * ir_to_string(prog: IRProgram): string
 *
 * IR을 출력 가능한 문자열로 변환
 */
fn ir_to_string(prog: IRProgram): string {
  var result = ""

  result = result + "╔════════════════════════════════════════╗\n"
  result = result + "║            IR Program                  ║\n"
  result = result + "╚════════════════════════════════════════╝\n"

  let i = 0
  while i < prog.blocks.length() {
    let block = prog.blocks[i]
    result = result + "\n" + block.name + ":\n"

    let j = 0
    while j < block.instructions.length() {
      let instr = block.instructions[j]
      result = result + "  " + opcode_to_string(instr.opcode) + " "

      if strlen(instr.result) > 0 {
        result = result + instr.result + " = "
      }

      if instr.operands.length() > 0 {
        result = result + instr.operands[0]
        let k = 1
        while k < instr.operands.length() {
          result = result + ", " + instr.operands[k]
          k = k + 1
        }
      }

      result = result + "\n"
      j = j + 1
    }

    i = i + 1
  }

  result = result + "\nTotal blocks: " + str(prog.blocks.length()) + "\n"
  result = result + "Total temp vars: " + str(prog.temp_count) + "\n"

  return result
}

// ============================================
// 유틸리티 함수
// ============================================

/**
 * contains(text: string, substr: string): bool
 */
fn contains(text: string, substr: string): bool {
  // 간단한 구현 (실제로는 더 효율적인 알고리즘 필요)
  let text_len = strlen(text)
  let substr_len = strlen(substr)

  if substr_len == 0 { return true }
  if substr_len > text_len { return false }

  let i = 0
  while i <= text_len - substr_len {
    let j = 0
    let match = true
    while j < substr_len {
      if substring(text, i + j, 1) != substring(substr, j, 1) {
        match = false
        break
      }
      j = j + 1
    }

    if match { return true }
    i = i + 1
  }

  return false
}

