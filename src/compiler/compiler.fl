// ============================================

fn main(): void {
  println("")
  println("╔════════════════════════════════════════╗")
  println("║   FreeLang Self-Hosting Compiler      ║")
  println("║   v1.0 (2026-03-06)                   ║")
  println("╚════════════════════════════════════════╝")
  println("")

  // 개별 단계 테스트
  test_parse_source()
  test_analyze_program()
  test_generate_ir()
  test_pipeline_integration()

  println("")
  println("═══════════════════════════════════════")
  println("Full Compilation Tests (compile())")
  println("═══════════════════════════════════════")
  println("")

  // Test Case 1: 기본 변수 선언
  let source1 = "let x = 5;"
  println("Test 1: " + source1)
  var result1 = compile(source1)

  if result1.success {
    println("✓ Compilation successful")
    println("  Errors: " + str(result1.error_count))
    println("  Compile time: " + str(result1.compile_time_ms) + " ms")
  } else {
    println("✗ Compilation failed")
    let i = 0
    while i < result1.messages.length() {
      println("  " + result1.messages[i])
      i = i + 1
    }
  }
  println("")

  // Test Case 2: 함수 정의
  let source2 = "fn add(x: i32, y: i32): i32 { return x + y; }"
  println("Test 2: " + source2)
  var result2 = compile(source2)

  if result2.success {
    println("✓ Compilation successful")
  } else {
    println("✗ Compilation failed")
  }
  println("")

  // Test Case 3: 복합 프로그램
  let source3 = "let x = 10; if x > 5 { println(x); }"
  println("Test 3: " + source3)
  var result3 = compile(source3)

  if result3.success {
    println("✓ Compilation successful")
    println("")
    println("Generated Assembly:")
    println("═══════════════════════════════════════")
    println(result3.output)
    println("═══════════════════════════════════════")
  } else {
    println("✗ Compilation failed")
  }
  println("")

  println("✅ Compiler main tests completed")
}
