/**
 * Phase 1 Week 3-4: Semantic Analyzer
 *
 * 타입 검사 및 변수/함수 검증
 * AST 호환 버전 (Compiler와 통합)
 * 작성: 2026-03-06
 * 통합: 2026-03-06 (Agent-3)
 */

// ============================================
// 의미분석 에러 타입
// ============================================

enum SemanticError {
  UNDEFINED_VARIABLE = 0,
  UNDEFINED_FUNCTION = 1,
  TYPE_MISMATCH = 2,
  UNDEFINED_FIELD = 3,
  WRONG_ARGUMENT_COUNT = 4,
  WRONG_ARGUMENT_TYPE = 5,
  INVALID_RETURN_TYPE = 6,
  INVALID_CONDITION_TYPE = 7,
  NON_ITERABLE = 8,
  DUPLICATE_DECLARATION = 9,
}

struct Diagnostic {
  error_code: i32,
  message: string,
  line: i32,
  col: i32,
}

struct TypeCheckResult {
  success: bool,
  errors: Array<Diagnostic>,
  warnings: Array<string>,
  symbol_count: i32,
}

// ============================================
// Semantic Analyzer 메인 구조
// ============================================

struct SemanticAnalyzer {
  symbol_table: SymbolTable,
  current_scope: i32,
  errors: Array<Diagnostic>,
  warnings: Array<string>,
  in_function: bool,
  return_type: Type,
}

/**
 * new_analyzer(): SemanticAnalyzer
 * 새로운 의미분석기 생성
 */
fn new_analyzer(): SemanticAnalyzer {
  var analyzer: SemanticAnalyzer
  analyzer.symbol_table = new_symbol_table()
  analyzer.current_scope = 0
  analyzer.errors = []
  analyzer.warnings = []
  analyzer.in_function = false
  analyzer.return_type = type_void()
  return analyzer
}

// ============================================
// 에러 리포팅
// ============================================

/**
 * report_error(analyzer, error_code, message, line, col): void
 */
fn report_error(
  analyzer: SemanticAnalyzer,
  error_code: i32,
  message: string,
  line: i32,
  col: i32
): void {
  var diag: Diagnostic
  diag.error_code = error_code
  diag.message = message
  diag.line = line
  diag.col = col
  analyzer.errors.push(diag)
}

// ============================================
// Variable 검증
// ============================================

/**
 * check_variable_declaration(analyzer, name, type, line, col): bool
 * 변수 선언 검증
 */
fn check_variable_declaration(
  analyzer: SemanticAnalyzer,
  name: string,
  type_str: string,
  line: i32,
  col: i32
): bool {
  // Symbol Table에 선언
  let success = declare(
    analyzer.symbol_table,
    name,
    0,  // VARIABLE
    type_str,
    line,
    col
  )

  if !success {
    report_error(
      analyzer,
      9,  // DUPLICATE_DECLARATION
      "duplicate declaration: " + name,
      line,
      col
    )
    return false
  }

  return true
}

/**
 * check_variable_use(analyzer, name, line, col): Type
 * 변수 사용 검증
 */
fn check_variable_use(
  analyzer: SemanticAnalyzer,
  name: string,
  line: i32,
  col: i32
): Type {
  let entry = lookup(analyzer.symbol_table, name)

  if !entry.defined {
    report_error(
      analyzer,
      0,  // UNDEFINED_VARIABLE
      "undefined variable: " + name,
      line,
      col
    )
    return type_void()
  }

  return type_i32()  // 간단화: 모두 i32로 반환
}

// ============================================
// Function 검증
// ============================================

/**
 * check_function_declaration(analyzer, name, params, return_type, line, col): bool
 * 함수 선언 검증
 */
fn check_function_declaration(
  analyzer: SemanticAnalyzer,
  name: string,
  param_count: i32,
  return_type_str: string,
  line: i32,
  col: i32
): bool {
  let success = declare(
    analyzer.symbol_table,
    name,
    1,  // FUNCTION
    "fn(...) -> " + return_type_str,
    line,
    col
  )

  if !success {
    report_error(
      analyzer,
      9,  // DUPLICATE_DECLARATION
      "duplicate function: " + name,
      line,
      col
    )
    return false
  }

  return true
}

/**
 * check_function_call(analyzer, name, arg_count, line, col): bool
 * 함수 호출 검증
 */
fn check_function_call(
  analyzer: SemanticAnalyzer,
  name: string,
  arg_count: i32,
  line: i32,
  col: i32
): bool {
  let entry = lookup(analyzer.symbol_table, name)

  if !entry.defined {
    report_error(
      analyzer,
      1,  // UNDEFINED_FUNCTION
      "undefined function: " + name,
      line,
      col
    )
    return false
  }

  // 간단화: 인수 개수 체크는 나중에
  return true
}

// ============================================
// Type 검증
// ============================================

/**
 * check_type_compatibility(t1: Type, t2: Type): bool
 * 두 타입이 호환되는지 확인
 */
fn check_type_compatibility(t1: Type, t2: Type): bool {
  if type_equal(t1, t2) {
    return true
  }

  // 숫자 타입 호환 (i32, i64, f64 간 변환 허용)
  if type_is_numeric(t1) && type_is_numeric(t2) {
    return true
  }

  return false
}

/**
 * check_assignment(analyzer, lhs_type: Type, rhs_type: Type, line, col): bool
 * 할당 검증
 */
fn check_assignment(
  analyzer: SemanticAnalyzer,
  lhs_type: Type,
  rhs_type: Type,
  line: i32,
  col: i32
): bool {
  if !check_type_compatibility(lhs_type, rhs_type) {
    report_error(
      analyzer,
      2,  // TYPE_MISMATCH
      "type mismatch in assignment",
      line,
      col
    )
    return false
  }

  return true
}

/**
 * check_binary_operation(analyzer, left_type: Type, op: string, right_type: Type, line, col): Type
 * 이항 연산 검증
 */
fn check_binary_operation(
  analyzer: SemanticAnalyzer,
  left_type: Type,
  op: string,
  right_type: Type,
  line: i32,
  col: i32
): Type {
  // 산술 연산 (+, -, *, /, %)
  if op == "+" || op == "-" || op == "*" || op == "/" || op == "%" {
    if !type_is_numeric(left_type) || !type_is_numeric(right_type) {
      report_error(
        analyzer,
        2,  // TYPE_MISMATCH
        "arithmetic operation requires numeric types",
        line,
        col
      )
      return type_void()
    }
    return left_type
  }

  // 논리 연산 (&&, ||)
  if op == "&&" || op == "||" {
    if left_type.kind != 4 || right_type.kind != 4 {
      report_error(
        analyzer,
        2,  // TYPE_MISMATCH
        "logical operation requires bool types",
        line,
        col
      )
      return type_void()
    }
    return type_bool()
  }

  // 비교 연산 (<, >, <=, >=, ==, !=)
  if op == "<" || op == ">" || op == "<=" || op == ">=" || op == "==" || op == "!=" {
    if !type_is_numeric(left_type) || !type_is_numeric(right_type) {
      report_error(
        analyzer,
        2,  // TYPE_MISMATCH
        "comparison requires numeric types",
        line,
        col
      )
      return type_void()
    }
    return type_bool()
  }

  return type_void()
}

/**
 * check_condition(analyzer, condition_type: Type, line, col): bool
 * 조건식 검증 (if, while)
 */
fn check_condition(
  analyzer: SemanticAnalyzer,
  condition_type: Type,
  line: i32,
  col: i32
): bool {
  if condition_type.kind != 4 {  // BOOL
    report_error(
      analyzer,
      7,  // INVALID_CONDITION_TYPE
      "condition must be bool type",
      line,
      col
    )
    return false
  }

  return true
}

/**
 * check_return_type(analyzer, actual_type: Type, expected_type: Type, line, col): bool
 * 반환 타입 검증
 */
fn check_return_type(
  analyzer: SemanticAnalyzer,
  actual_type: Type,
  expected_type: Type,
  line: i32,
  col: i32
): bool {
  if !check_type_compatibility(actual_type, expected_type) {
    report_error(
      analyzer,
      6,  // INVALID_RETURN_TYPE
      "return type mismatch",
      line,
      col
    )
    return false
  }

  return true
}

// ============================================
// 테스트
// ============================================

fn test_semantic_analyzer(): void {
  println("")
  println("🧪 Testing Semantic Analyzer...")
  println("")

  var analyzer = new_analyzer()

  // Test 1: Variable declaration
  let success1 = check_variable_declaration(analyzer, "x", "i32", 1, 0)
  if success1 {
    println("✓ Variable declaration: x: i32")
  } else {
    println("✗ Variable declaration failed")
  }

  // Test 2: Variable use
  let var_type = check_variable_use(analyzer, "x", 2, 0)
  println("✓ Variable use: x (type " + type_to_string(var_type) + ")")

  // Test 3: Undefined variable
  let undef = check_variable_use(analyzer, "undefined_var", 3, 0)
  println("✓ Undefined variable check: error reported")

  // Test 4: Function declaration
  let fn_success = check_function_declaration(analyzer, "add", 2, "i32", 5, 0)
  if fn_success {
    println("✓ Function declaration: add(2 args) -> i32")
  }

  // Test 5: Function call
  let call_success = check_function_call(analyzer, "add", 2, 6, 0)
  if call_success {
    println("✓ Function call: add(...)")
  }

  // Test 6: Type compatibility
  let t1 = type_i32()
  let t2 = type_i32()
  if check_type_compatibility(t1, t2) {
    println("✓ Type compatibility: i32 compatible with i32")
  }

  // Test 7: Binary operation
  let result = check_binary_operation(analyzer, type_i32(), "+", type_i32(), 10, 0)
  println("✓ Binary operation: i32 + i32 -> " + type_to_string(result))

  // Test 8: Condition check
  let cond_ok = check_condition(analyzer, type_bool(), 12, 0)
  if cond_ok {
    println("✓ Condition check: bool is valid condition")
  }

  // Test 9: Invalid condition
  let cond_fail = check_condition(analyzer, type_i32(), 13, 0)
  println("✓ Invalid condition check: error reported")

  // Test 10: Error count
  let error_count = analyzer.errors.length()
  println("")
  println("Total errors detected: " + str(error_count))
  println("✅ Semantic analyzer tests completed")
}

fn main(): void {
  test_semantic_analyzer()
}
