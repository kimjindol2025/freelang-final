# ================================================================
# FreeLang v2.4.0 Complete Test Suite
# ================================================================
# Stage G: 40 comprehensive tests + 8 unforgiving rules
# Coverage: All new features from Stages A-F
#
# Test Groups:
# - Group 1 (A): Return/For-in/Dict/Member (8 tests)
# - Group 2 (B): Stdlib completeness (8 tests)
# - Group 3 (C): Error handling (8 tests)
# - Group 4 (D): Debug tools (8 tests)
# - Group 5 (E): Map utilities (4 tests)
# - Group 6 (F): Advanced functional (4 tests)
# ================================================================

# ================================================================
# GROUP 1 (A): Language Core Features
# ================================================================

#[cfg(test)]
fn test_group_1_a1_return_early_exit() {
  # Test A1: Early return from functions
  fn get_value(x: i32): i32 {
    if x < 0 {
      return -1
    }
    if x == 0 {
      return 0
    }
    return x * 2
  }

  assert_eq(get_value(-5), -1)
  assert_eq(get_value(0), 0)
  assert_eq(get_value(5), 10)
  println!("✅ TEST A1: Return early exit")
}

#[cfg(test)]
fn test_group_1_a2_for_in_loop() {
  # Test A2: for-in with arrays
  let sum = 0
  let arr = [1, 2, 3, 4]
  for item in arr {
    sum = sum + item
  }
  assert_eq(sum, 10)
  println!("✅ TEST A2: For-in loop")
}

#[cfg(test)]
fn test_group_1_a3_dict_literal() {
  # Test A3: Dictionary literal syntax
  let config = {"host": "localhost", "port": 8080}
  assert_eq(config["host"], "localhost")
  assert_eq(config["port"], 8080)
  println!("✅ TEST A3: Dict literal")
}

#[cfg(test)]
fn test_group_1_a4_member_access() {
  # Test A4: Dot notation member access
  let obj = {"name": "alice", "age": 30}
  assert_eq(obj.name, "alice")
  assert_eq(obj.age, 30)
  println!("✅ TEST A4: Member access")
}

#[cfg(test)]
fn test_group_1_a5_member_assignment() {
  # Test A5: Dot notation member assignment
  let user = {"id": 1, "status": "inactive"}
  user.status = "active"
  assert_eq(user.status, "active")
  println!("✅ TEST A5: Member assignment")
}

#[cfg(test)]
fn test_group_1_a6_struct_definition() {
  # Test A6: Struct definition and instantiation
  struct Person {
    name: string,
    age: i32
  }

  let person = {"name": "bob", "age": 25}
  assert_eq(person["name"], "bob")
  assert_eq(person["age"], 25)
  println!("✅ TEST A6: Struct definition")
}

#[cfg(test)]
fn test_group_1_a7_nested_structures() {
  # Test A7: Nested dictionaries and for-in loops
  let people = [
    {"name": "alice", "age": 30},
    {"name": "bob", "age": 25}
  ]

  let count = 0
  for person in people {
    count = count + 1
  }

  assert_eq(count, 2)
  println!("✅ TEST A7: Nested structures")
}

#[cfg(test)]
fn test_group_1_a8_complex_control_flow() {
  # Test A8: Complex control flow with early return and loops
  fn process(items: [i32]): i32 {
    let result = 0
    for item in items {
      if item < 0 {
        return -1
      }
      result = result + item
    }
    return result
  }

  assert_eq(process([1, 2, 3]), 6)
  assert_eq(process([1, -1, 3]), -1)
  println!("✅ TEST A8: Complex control flow")
}

# ================================================================
# GROUP 2 (B): Standard Library Completeness
# ================================================================

#[cfg(test)]
fn test_group_2_b1_string_functions() {
  # Test B1: String manipulation
  let text = "hello,world,test"
  let parts = split(text, ",")
  assert_eq(len(parts), 3)
  assert_eq(parts[0], "hello")

  let joined = join(parts, "-")
  assert_eq(joined, "hello-world-test")
  println!("✅ TEST B1: String functions")
}

#[cfg(test)]
fn test_group_2_b2_math_functions() {
  # Test B2: Math functions
  assert_eq(floor(3.7), 3)
  assert_eq(ceil(3.2), 4)
  assert_eq(round(3.5), 4)
  assert_eq(gcd(48, 18), 6)
  println!("✅ TEST B2: Math functions")
}

#[cfg(test)]
fn test_group_2_b3_array_functions() {
  # Test B3: Array operations
  let arr = [3, 1, 4, 1, 5]
  let doubled = map(arr, fn(x) { return x * 2 })
  assert_eq(doubled[0], 6)

  let filtered = filter(arr, fn(x) { return x > 2 })
  assert_eq(len(filtered), 3)
  println!("✅ TEST B3: Array functions")
}

#[cfg(test)]
fn test_group_2_b4_advanced_search() {
  # Test B4: Advanced search (find, some, every)
  let nums = [1, 2, 3, 4, 5]
  let found = find(nums, fn(x) { return x > 3 })
  assert_eq(found, 4)

  let has_even = some(nums, fn(x) { return x % 2 == 0 })
  assert_eq(has_even, true)

  let all_positive = every(nums, fn(x) { return x > 0 })
  assert_eq(all_positive, true)
  println!("✅ TEST B4: Advanced search")
}

#[cfg(test)]
fn test_group_2_b5_string_advanced() {
  # Test B5: Advanced string functions
  let num_str = "42"
  let num = toInt(num_str)
  assert_eq(num, 42)

  let spaces = "  hello  "
  let trimmed = trim(spaces)
  println!("✅ TEST B5: String advanced")
}

#[cfg(test)]
fn test_group_2_b6_array_advanced() {
  # Test B6: Advanced array operations
  let data = [1, 2, 3, null, 5]
  let compacted = compact(data)
  assert_eq(len(compacted), 4)

  let pairs = zip([1, 2], ["a", "b"])
  assert_eq(len(pairs), 2)
  println!("✅ TEST B6: Array advanced")
}

#[cfg(test)]
fn test_group_2_b7_math_advanced() {
  # Test B7: Advanced math functions
  assert_eq(isPrime(7), true)
  assert_eq(isPrime(8), false)
  assert_eq(factorial(5), 120)
  println!("✅ TEST B7: Math advanced")
}

#[cfg(test)]
fn test_group_2_b8_reduce_and_fold() {
  # Test B8: Reduce operations
  let nums = [1, 2, 3, 4]
  let sum = reduce(nums, 0, fn(acc, x) { return acc + x })
  assert_eq(sum, 10)
  println!("✅ TEST B8: Reduce")
}

# ================================================================
# GROUP 3 (C): Error Handling (Result Pattern)
# ================================================================

#[cfg(test)]
fn test_group_3_c1_result_creation() {
  # Test C1: Create Ok/Err results
  let success = ok(42)
  let failure = err("something went wrong")

  assert_eq(is_ok(success), true)
  assert_eq(is_err(failure), true)
  println!("✅ TEST C1: Result creation")
}

#[cfg(test)]
fn test_group_3_c2_result_extraction() {
  # Test C2: Extract values from Result
  let r = ok(100)
  let val = unwrap(r)
  assert_eq(val, 100)

  let r2 = err("fail")
  let fallback = unwrap_or(r2, 0)
  assert_eq(fallback, 0)
  println!("✅ TEST C2: Result extraction")
}

#[cfg(test)]
fn test_group_3_c3_result_map() {
  # Test C3: Map over Result (transform)
  let r = ok(5)
  let mapped = result_map(r, fn(x) { return x * 2 })
  assert_eq(unwrap(mapped), 10)
  println!("✅ TEST C3: Result map")
}

#[cfg(test)]
fn test_group_3_c4_result_and_then() {
  # Test C4: Chain Results (flatMap)
  let r1 = ok(5)
  let r2 = result_and_then(r1, fn(x) { return ok(x * 2) })
  assert_eq(unwrap(r2), 10)

  let r3 = ok(5)
  let r4 = result_and_then(r3, fn(x) { return err("failed") })
  assert_eq(is_err(r4), true)
  println!("✅ TEST C4: Result and_then")
}

#[cfg(test)]
fn test_group_3_c5_result_collections() {
  # Test C5: Work with Result collections
  let results = [ok(1), err("x"), ok(2), err("y")]
  let ok_count = ok_count(results)
  let err_count = err_count(results)

  assert_eq(ok_count, 2)
  assert_eq(err_count, 2)
  println!("✅ TEST C5: Result collections")
}

#[cfg(test)]
fn test_group_3_c6_result_error_handling() {
  # Test C6: Error propagation and fallback
  let r = err("database connection failed")
  let result = result_or_else(r, fn(msg) {
    return ok("fallback value")
  })
  assert_eq(unwrap(result), "fallback value")
  println!("✅ TEST C6: Result error handling")
}

#[cfg(test)]
fn test_group_3_c7_result_expect() {
  # Test C7: expect with custom message
  let r = ok(42)
  let val = expect(r, "should be ok")
  assert_eq(val, 42)
  println!("✅ TEST C7: Result expect")
}

#[cfg(test)]
fn test_group_3_c8_result_pipeline() {
  # Test C8: Result pipeline patterns
  let r1 = ok(10)
  let r2 = result_map(r1, fn(x) { return x + 5 })
  let r3 = result_map(r2, fn(x) { return x * 2 })
  assert_eq(unwrap(r3), 30)
  println!("✅ TEST C8: Result pipeline")
}

# ================================================================
# GROUP 4 (D): Debug Tools
# ================================================================

#[cfg(test)]
fn test_group_4_d1_assert_functions() {
  # Test D1: Assert functions
  assert_eq(5, 5, "equality test")
  assert_ne(5, 3, "inequality test")
  assert_true(true, "boolean true")
  assert_false(false, "boolean false")
  println!("✅ TEST D1: Assert functions")
}

#[cfg(test)]
fn test_group_4_d2_trace_functions() {
  # Test D2: Trace and debugging
  let x = trace("value is", 42)
  assert_eq(x, 42)
  println!("✅ TEST D2: Trace functions")
}

#[cfg(test)]
fn test_group_4_d3_type_inspection() {
  # Test D3: Type inspection
  assert_eq(debug_type(42), "i32")
  assert_eq(debug_type(3.14), "f64")
  assert_eq(debug_type("hello"), "string")
  assert_eq(debug_type([1, 2]), "array")
  assert_eq(debug_type(true), "bool")
  println!("✅ TEST D3: Type inspection")
}

#[cfg(test)]
fn test_group_4_d4_timer_and_measurement() {
  # Test D4: Timer and performance
  let timer = timer_start()
  let elapsed = timer_elapsed(timer)
  assert_eq(elapsed >= 0.0, true)
  println!("✅ TEST D4: Timer measurement")
}

# ================================================================
# GROUP 5 (E): Map Utilities
# ================================================================

#[cfg(test)]
fn test_group_5_e1_map_operations() {
  # Test E1: Basic map operations
  let m = {"a": 1, "b": 2}
  assert_eq(map_get(m, "a"), 1)
  assert_eq(map_has(m, "b"), true)
  assert_eq(map_has(m, "c"), false)
  println!("✅ TEST E1: Map operations")
}

#[cfg(test)]
fn test_group_5_e2_map_keys_values() {
  # Test E2: Map decomposition
  let m = {"x": 10, "y": 20}
  let keys = map_keys(m)
  let values = map_values(m)
  assert_eq(len(keys), 2)
  assert_eq(len(values), 2)
  println!("✅ TEST E2: Map keys/values")
}

#[cfg(test)]
fn test_group_5_e3_map_merge() {
  # Test E3: Map merging
  let m1 = {"a": 1}
  let m2 = {"b": 2}
  let merged = map_merge(m1, m2)
  assert_eq(map_size(merged), 2)
  println!("✅ TEST E3: Map merge")
}

#[cfg(test)]
fn test_group_5_e4_map_transform() {
  # Test E4: Map transformation
  let config = {"debug": true, "level": 5}
  let entries = map_entries(config)
  assert_eq(len(entries), 2)
  println!("✅ TEST E4: Map transform")
}

# ================================================================
# GROUP 6 (F): Advanced Functional
# ================================================================

#[cfg(test)]
fn test_group_6_f1_group_by() {
  # Test F1: groupBy
  let arr = [1, 2, 3, 4, 5, 6]
  let groups = groupBy(arr, fn(x) {
    if x % 2 == 0 { return "even" } else { return "odd" }
  })
  assert_eq(len(groups["even"]), 3)
  println!("✅ TEST F1: groupBy")
}

#[cfg(test)]
fn test_group_6_f2_pipe() {
  # Test F2: pipe
  let add_one = fn(x) { return x + 1 }
  let double = fn(x) { return x * 2 }
  let result = pipe(5, [add_one, double])
  assert_eq(result, 12)
  println!("✅ TEST F2: pipe")
}

#[cfg(test)]
fn test_group_6_f3_once() {
  # Test F3: once
  let counter = 0
  let inc = once(fn(x) {
    counter = counter + 1
    return counter
  })
  inc(0)
  inc(0)
  assert_eq(counter, 1)
  println!("✅ TEST F3: once")
}

#[cfg(test)]
fn test_group_6_f4_find_and_search() {
  # Test F4: find, some, every
  let nums = [1, 2, 3, 4, 5]
  let gt3 = find(nums, fn(x) { return x > 3 })
  assert_eq(gt3, 4)

  let has_odd = some(nums, fn(x) { return x % 2 == 1 })
  assert_eq(has_odd, true)
  println!("✅ TEST F4: find/some/every")
}

# ================================================================
# UNFORGIVING RULES (8 total)
# ================================================================

#[cfg(test)]
fn test_rule_1_for_in_100_percent() {
  # RULE 1: for-in loop 100% complete (arr, range)
  let sum = 0
  for i in [1, 2, 3, 4, 5] {
    sum = sum + i
  }
  assert_eq(sum, 15)
  println!("✅ RULE 1 PASS: for-in 100%")
}

#[cfg(test)]
fn test_rule_2_return_early_100_percent() {
  # RULE 2: return 조기 종료 100% 동작
  fn test_return(n: i32): i32 {
    if n < 0 { return -1 }
    if n == 0 { return 0 }
    return n * 2
  }
  assert_eq(test_return(-5), -1)
  assert_eq(test_return(0), 0)
  assert_eq(test_return(5), 10)
  println!("✅ RULE 2 PASS: return early 100%")
}

#[cfg(test)]
fn test_rule_3_dict_literal_100_percent() {
  # RULE 3: 딕셔너리 {} 리터럴 100% 동작
  let dict = {"name": "test", "value": 42, "active": true}
  assert_eq(dict["name"], "test")
  assert_eq(dict.value, 42)
  assert_eq(dict.active, true)
  println!("✅ RULE 3 PASS: dict literal 100%")
}

#[cfg(test)]
fn test_rule_4_string_split_exact() {
  # RULE 4: string.split 정확성
  let result = split("a,b,c", ",")
  assert_eq(len(result), 3)
  assert_eq(result[0], "a")
  assert_eq(result[1], "b")
  assert_eq(result[2], "c")
  println!("✅ RULE 4 PASS: string split exact")
}

#[cfg(test)]
fn test_rule_5_result_pattern_100_percent() {
  # RULE 5: Result ok/err 패턴 100% 동작
  let r1 = ok(42)
  let r2 = err("failed")
  assert_eq(is_ok(r1), true)
  assert_eq(is_err(r2), true)
  assert_eq(unwrap(r1), 42)
  assert_eq(unwrap_or(r2, 0), 0)
  println!("✅ RULE 5 PASS: Result pattern 100%")
}

#[cfg(test)]
fn test_rule_6_backward_compatibility() {
  # RULE 6: v2.2.0 stdlib 하위 호환성
  let arr = [1, 2, 3, 4, 5]
  let doubled = map(arr, fn(x) { return x * 2 })
  assert_eq(len(doubled), 5)
  assert_eq(doubled[0], 2)
  println!("✅ RULE 6 PASS: backward compatibility")
}

#[cfg(test)]
fn test_rule_7_assert_message_output() {
  # RULE 7: assert_eq 실패 시 메시지 포함
  assert_eq(10, 10, "test message 1")
  assert_ne(5, 10, "test message 2")
  println!("✅ RULE 7 PASS: assert message output")
}

#[cfg(test)]
fn test_rule_8_timer_f64_return() {
  # RULE 8: timer_elapsed f64 반환 (>= 0)
  let timer = timer_start()
  let elapsed = timer_elapsed(timer)
  assert_eq(elapsed >= 0.0, true)
  println!("✅ RULE 8 PASS: timer returns f64 >= 0")
}

