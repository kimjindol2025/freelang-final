fn main() {
  println("═══════════════════════════════════════════")
  println("  Extended Builtins Integration Test")
  println("═══════════════════════════════════════════")
  println("")

  println("Test 1: Random Functions")
  let r1 = random()
  println("  random() = " + str(r1))
  let r2 = random_int(1, 100)
  println("  random_int(1, 100) = " + str(r2))
  let r3 = random_float(0.0, 1.0)
  println("  random_float(0.0, 1.0) = " + str(r3))
  println("  ✅ Pass")
  println("")

  println("Test 2: Array Utility Functions")
  let arr = [1, 2, 3, 4, 5]
  let sum = array_sum(arr)
  println("  array_sum([1,2,3,4,5]) = " + str(sum))
  let avg = array_avg(arr)
  println("  array_avg([1,2,3,4,5]) = " + str(avg))
  let min = array_min(arr)
  println("  array_min([1,2,3,4,5]) = " + str(min))
  let max = array_max(arr)
  println("  array_max([1,2,3,4,5]) = " + str(max))
  println("  ✅ Pass")
  println("")

  println("Test 3: String Utility Functions")
  let text = "hello world"
  let upper = string_uppercase(text)
  println("  string_uppercase('hello world') = " + upper)
  let lower = string_lowercase("HELLO WORLD")
  println("  string_lowercase('HELLO WORLD') = " + lower)
  let trimmed = string_trim("  hello  ")
  println("  string_trim('  hello  ') = '" + trimmed + "'")
  let split = string_split("a,b,c", ",")
  println("  string_split('a,b,c', ',') = " + str(len(split)) + " parts")
  let joined = string_join(["x", "y", "z"], "-")
  println("  string_join(['x','y','z'], '-') = " + joined)
  let repeated = string_repeat("hi", 3)
  println("  string_repeat('hi', 3) = " + repeated)
  println("  ✅ Pass")
  println("")

  println("Test 4: Hash Function")
  let h1 = hash("test")
  println("  hash('test') = " + h1)
  println("  ✅ Pass")
  println("")

  println("Test 5: UUID Function")
  let id = uuid()
  println("  uuid() = " + id)
  println("  ✅ Pass")
  println("")

  println("═══════════════════════════════════════════")
  println("  ✅ All extended builtin tests passed!")
  println("═══════════════════════════════════════════")
}

main()
